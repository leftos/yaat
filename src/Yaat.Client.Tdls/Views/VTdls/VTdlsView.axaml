<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             xmlns:svc="using:Yaat.Client.Services"
             x:Class="Yaat.Client.Views.VTdls.VTdlsView"
             x:DataType="vm:VTdlsViewModel"
             x:CompileBindings="True"
             Focusable="True">

    <UserControl.Resources>
        <!-- Match upstream vTDLS look: black chrome top bar, green list headers,
             white list backgrounds, dark-on-light footer. See docs/vtdls/img/
             tdls.png + tdls-empty.png + flight-plan.png. -->
        <SolidColorBrush x:Key="VTdlsChromeBg" Color="#000000"/>
        <SolidColorBrush x:Key="VTdlsListHeaderBg" Color="#1ec51e"/>
        <SolidColorBrush x:Key="VTdlsListBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="VTdlsListFg" Color="#0000bb"/>
        <SolidColorBrush x:Key="VTdlsFooterBg" Color="#f0f0f0"/>
        <SolidColorBrush x:Key="VTdlsFooterFg" Color="#202020"/>
        <SolidColorBrush x:Key="VTdlsFacilityButtonBg" Color="#1ec51e"/>
        <SolidColorBrush x:Key="VTdlsSelectedBg" Color="#000000"/>
        <SolidColorBrush x:Key="VTdlsSelectedFg" Color="#ffffff"/>
        <SolidColorBrush x:Key="VTdlsListBorder" Color="#a0a0a0"/>
        <!-- Editor label / heading text. Swaps to a light shade in dark mode
             via ApplyTheme so the form stays legible on dark backgrounds. -->
        <SolidColorBrush x:Key="VTdlsEditorTextFg" Color="#000000"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Tighter list items so the column-wrap density matches upstream. -->
        <Style Selector="ListBox.tdls > ListBoxItem">
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource VTdlsListFg}"/>
        </Style>
        <Style Selector="ListBox.tdls > ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource VTdlsSelectedBg}"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource VTdlsSelectedFg}"/>
        </Style>
        <Style Selector="TextBlock.tdls-list-header">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="28,Auto,*,Auto,22">

        <!-- ── Top chrome bar (header) ─────────────────────────────────────
             Upstream layout: facility-chooser buttons + TIMS / ERAM / CPDLC
             status indicators on the LEFT, FDIO / DCL / DATIS on the RIGHT.
             We render the facility button as the only interactive element;
             the rest are decorative parity placeholders. -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" Background="{DynamicResource VTdlsChromeBg}">
            <Button Grid.Column="0"
                    x:Name="FacilityButton"
                    Content="{Binding FacilityId, FallbackValue='(none)'}"
                    ToolTip.Tip="Switch this window's TDLS facility"
                    Margin="4,2"
                    Padding="8,1"
                    Background="{DynamicResource VTdlsFacilityButtonBg}"
                    Foreground="Black"
                    BorderBrush="Black"
                    BorderThickness="1"
                    FontFamily="{StaticResource MonoFont}"
                    FontWeight="Bold"
                    FontSize="12"
                    Click="OnFacilityButtonClick"/>

            <!-- Decorative parity buttons — these are real on upstream but not
                 simulated. They stay rendered so a controller's muscle memory
                 lines up with what they expect to see. -->
            <Border Grid.Column="1" Background="{DynamicResource VTdlsFacilityButtonBg}" Margin="2,4" Padding="8,1" BorderBrush="Black" BorderThickness="1">
                <TextBlock Text="TIMS" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="12" Foreground="Black"/>
            </Border>
            <Border Grid.Column="2" Background="{DynamicResource VTdlsFacilityButtonBg}" Margin="2,4" Padding="8,1" BorderBrush="Black" BorderThickness="1">
                <TextBlock Text="ERAM" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="12" Foreground="Black"/>
            </Border>

            <!-- Right-side decorative status panes — FDIO / DCL / DATIS. Real
                 vTDLS uses these to indicate uplink status; we render them as
                 plain badges so the chrome doesn't look empty. -->
            <Border Grid.Column="4" Background="#0033cc" Margin="2,4" Padding="8,1" BorderBrush="White" BorderThickness="1">
                <TextBlock Text="FDIO" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="12" Foreground="White"/>
            </Border>
            <Border Grid.Column="5" Background="Black" Margin="2,4" Padding="8,1" BorderBrush="White" BorderThickness="1">
                <TextBlock Text="DCL" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="12" Foreground="White"/>
            </Border>
            <Border Grid.Column="6" Background="#cc00cc" Margin="2,4,6,4" Padding="8,1" BorderBrush="White" BorderThickness="1">
                <TextBlock Text="DATIS" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="12" Foreground="White"/>
            </Border>
        </Grid>

        <!-- ── DCL list (top, full width, column-wrapping) ────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource VTdlsListBg}"
                BorderBrush="{DynamicResource VTdlsListBorder}"
                BorderThickness="1"
                MinHeight="180">
            <Grid RowDefinitions="22,*">
                <Border Grid.Row="0" Background="{DynamicResource VTdlsListHeaderBg}">
                    <TextBlock Text="DCL" Classes="tdls-list-header"/>
                </Border>
                <!-- ItemsRepeater inside a ScrollViewer with a horizontal-wrap
                     ItemsPanel gives the column-flow layout upstream uses:
                     items stack downward, then start a new column when the
                     panel height fills. -->
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ListBox x:Name="DclListBox"
                             Classes="tdls"
                             ItemsSource="{Binding DclItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="12">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:TdlsItemViewModel">
                                <TextBlock Text="{Binding AircraftId}" MinWidth="80"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── PDC / CPDLC row (50/50 below DCL) ──────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*">

            <!-- PDC -->
            <Border Grid.Column="0"
                    Background="{DynamicResource VTdlsListBg}"
                    BorderBrush="{DynamicResource VTdlsListBorder}"
                    BorderThickness="1">
                <Grid RowDefinitions="22,*">
                    <Border Grid.Row="0" Background="{DynamicResource VTdlsListHeaderBg}">
                        <TextBlock Text="PDC" Classes="tdls-list-header"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             x:Name="PdcListBox"
                             Classes="tdls"
                             ItemsSource="{Binding PdcItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:TdlsItemViewModel">
                                <TextBlock Text="{Binding AircraftId}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- CPDLC — decorative parity; never populates (VATSIM doesn't simulate CPDLC) -->
            <Border Grid.Column="1"
                    Background="{DynamicResource VTdlsListBg}"
                    BorderBrush="{DynamicResource VTdlsListBorder}"
                    BorderThickness="1">
                <Grid RowDefinitions="22,*">
                    <Border Grid.Row="0" Background="{DynamicResource VTdlsListHeaderBg}">
                        <TextBlock Text="CPDLC" Classes="tdls-list-header"/>
                    </Border>
                    <!-- Intentionally empty body — upstream renders the list as
                         pure visual parity. No "not simulated" label per the
                         original spec; the empty pane IS the indication. -->
                </Grid>
            </Border>
        </Grid>

        <!-- ── Flight-plan editor (visible only when a DCL item is selected) ──
             Layout mirrors docs/vtdls/img/flight-plan.png and the field order
             documented in §Selecting PDC Field Values: Expect, then SID /
             Transition / Climb out / Climb via / Maintain, then Contact info /
             Departure frequency, then Local info. Buttons: Dump bottom-left,
             Cancel + Send bottom-right. All dropdowns are ComboBoxes —
             "Only values predefined by the Facility Engineer may be selected"
             (upstream §Selecting PDC Field Values). -->
        <Border Grid.Row="3"
                IsVisible="{Binding Editor, Converter={x:Static ObjectConverters.IsNotNull}}"
                Background="{DynamicResource VTdlsListBg}"
                BorderBrush="{DynamicResource VTdlsListBorder}"
                BorderThickness="1"
                Padding="8">
            <StackPanel DataContext="{Binding Editor}" Orientation="Vertical">

                <!-- Flight-plan header strip — matches the position of fields
                     A-H in docs/vtdls/img/flight-plan.png:
                       Row 1:  A (callsign, bold)            B C (beacon + route + /HHMM ETE)
                       Row 2:  D (type/equip)  E (proposed dep time)     F (remarks, right-aligned)
                       Row 3:  G (CID)  H (cruise FL)
                     Read-only; amendments happen through the radar client
                     ("Flight plans cannot be amended through TDLS"). -->
                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="60,Auto,8,*,8,Auto" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0" Text="{Binding Callsign}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <TextBlock Grid.Column="1" Text="{Binding FlightPlan.AssignedBeaconCode, StringFormat='\{0:D4\}', FallbackValue=''}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding FlightPlan.RouteDisplay, FallbackValue=''}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="60,Auto,16,Auto,16,*" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0" Text="{Binding FlightPlan.TypeAndEquipment, FallbackValue=''}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <TextBlock Grid.Column="1" Text="" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <TextBlock Grid.Column="5" Text="{Binding FlightPlan.RemarksDisplay, FallbackValue=''}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}" TextTrimming="CharacterEllipsis" TextAlignment="Right"/>
                    </Grid>
                    <Grid ColumnDefinitions="60,Auto" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0" Text="{Binding FlightPlan.Cid, FallbackValue=''}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <TextBlock Grid.Column="1" Text="{Binding FlightPlan.CruiseFlightLevel, StringFormat='\{0:000\}', FallbackValue=''}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                    </Grid>
                </StackPanel>

                <!-- Dropdown row 1: SID | Transition (the two narrow pickers
                     occupy the top-left, matching upstream's flight-plan.png
                     where SSOXS6 + "- - - -" sit alone above the wider row). -->
                <Grid ColumnDefinitions="2*,2*,11*" Margin="0,0,0,4">
                    <StackPanel Grid.Column="0" Margin="2,0">
                        <TextBlock Text="SID" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding Sids}"
                                  SelectedItem="{Binding SelectedSid, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="2,0">
                        <TextBlock Text="Transition" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding Transitions}"
                                  SelectedItem="{Binding SelectedTransition, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Dropdown row 2: Expect | Climb out | Climb via | Maintain.
                     Climb via takes the lion's share (~50%) because it carries
                     the long "CLIMB VIA SID EXCEPT MAINTAIN FLxxx" phrasing.
                     Width ratios match docs/vtdls/img/flight-plan.png. -->
                <Grid ColumnDefinitions="2*,2*,7*,2*" Margin="0,0,0,4">
                    <StackPanel Grid.Column="0" Margin="2,0">
                        <TextBlock Text="Expect" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding Expects}"
                                  SelectedValue="{Binding Expect, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Value}"
                                  DisplayMemberBinding="{Binding Value}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="2,0">
                        <TextBlock Text="Climb out" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding Climbouts}"
                                  SelectedValue="{Binding Climbout, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Value}"
                                  DisplayMemberBinding="{Binding Value}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="2,0">
                        <TextBlock Text="Climb via" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding Climbvias}"
                                  SelectedValue="{Binding Climbvia, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Value}"
                                  DisplayMemberBinding="{Binding Value}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="2,0">
                        <TextBlock Text="Maintain" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding InitialAlts}"
                                  SelectedValue="{Binding InitialAlt, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Value}"
                                  DisplayMemberBinding="{Binding Value}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Dropdown row 3: Contact info on the left (~40%), gap, then
                     Departure frequency tucked on the right (~15%), mirroring
                     the "CTC 121.65 TO PUSH … DEP FREQ 133.0" line in the
                     upstream screenshot. -->
                <Grid ColumnDefinitions="4*,7*,2*" Margin="0,0,0,4">
                    <StackPanel Grid.Column="0" Margin="2,0">
                        <TextBlock Text="Contact info" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding ContactInfos}"
                                  SelectedValue="{Binding ContactInfo, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Value}"
                                  DisplayMemberBinding="{Binding Value}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="2,0">
                        <TextBlock Text="Departure frequency" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding DepFreqs}"
                                  SelectedValue="{Binding DepFreq, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Value}"
                                  DisplayMemberBinding="{Binding Value}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Dropdown row 4: Local info, ~40% width matching the
                     narrower "- - - -" pill in the upstream screenshot. -->
                <Grid ColumnDefinitions="4*,9*" Margin="0,0,0,8">
                    <StackPanel Grid.Column="0" Margin="2,0">
                        <TextBlock Text="Local info" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{DynamicResource VTdlsEditorTextFg}"/>
                        <ComboBox ItemsSource="{Binding LocalInfos}"
                                  SelectedValue="{Binding LocalInfo, Mode=TwoWay}"
                                  SelectedValueBinding="{Binding Value}"
                                  DisplayMemberBinding="{Binding Value}"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="{StaticResource MonoFont}" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Buttons row: Dump bottom-left, Cancel + Send bottom-right. -->
                <Grid ColumnDefinitions="*,*">
                    <Button Grid.Column="0" Content="Dump (F4)"
                            Click="OnDumpClick"
                            HorizontalAlignment="Left"
                            FontFamily="{StaticResource MonoFont}" FontSize="11"
                            Padding="10,2"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel (F10)"
                                Click="OnCancelClick"
                                FontFamily="{StaticResource MonoFont}" FontSize="11"
                                Margin="0,0,6,0"
                                Padding="10,2"/>
                        <Button Content="Send (F12)"
                                Command="{Binding SendCommand}"
                                IsEnabled="{Binding IsSendEnabled}"
                                FontFamily="{StaticResource MonoFont}" FontSize="11"
                                FontWeight="Bold"
                                Padding="10,2"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Footer: clearance-type status (left) + decorative status info + Zulu clock (right) ── -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Background="{DynamicResource VTdlsFooterBg}">
            <TextBlock Grid.Column="0"
                       x:Name="FooterStatus"
                       Text="CLEARANCE TYPE: PDC"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       Foreground="{DynamicResource VTdlsFooterFg}"/>
            <TextBlock Grid.Column="1"
                       Text="PDC ADR SUPR: ALWAYS    CAF: ON    PDC AUTO: OFF    CPDLC AUTO: OFF"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource VTdlsFooterFg}"/>
            <TextBlock Grid.Column="2"
                       x:Name="FooterZuluClock"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="11"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="{DynamicResource VTdlsFooterFg}"/>
        </Grid>

        <!-- Disconnected banner — covers everything when offline. -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#cc992020"
                BorderBrush="#cc4040"
                BorderThickness="0,0,0,1"
                ZIndex="999"
                IsHitTestVisible="False"
                IsVisible="{Binding !IsConnected}">
            <TextBlock Text="DISCONNECTED — read-only until reconnect"
                       Foreground="White"
                       FontFamily="{StaticResource MonoFont}"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Padding="8,4"/>
        </Border>
    </Grid>
</UserControl>
