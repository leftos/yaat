<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Yaat.Client.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#B0B0B0" />
        <!-- Embedded JetBrains Mono is primary so the strip view renders the
             same monospace shape on desktop and in the WASM browser tab.
             System fallbacks remain for environments where the embedded
             font fails to register; "monospace" is the CSS-style generic
             that Skia honors as a last resort. -->
        <FontFamily x:Key="MonoFont">fonts:JetBrainsMono#JetBrains Mono,Consolas,Menlo,DejaVu Sans Mono,monospace</FontFamily>
        <!-- CRC vStrips palette — cream-on-grey strip cells with red field numbers,
             handwriting-styled user annotations, and typed separator bands.
             Matches docs/crc/img/departure-strip.png and docs/crc/img/separators.png. -->
        <!-- Annotation / separator label cells. Desktop has Segoe Script
             (Windows) or Lucida Handwriting / Comic Sans MS (mac+linux);
             WASM has none of those, so falls through to embedded JetBrains
             Mono — loses the script feel in the browser tab but at least
             the ✓ checkmark substitution renders (Inter has no checkmark
             glyph, JBM does). -->
        <FontFamily x:Key="StripScriptFont">Segoe Script,Lucida Handwriting,Comic Sans MS,fonts:JetBrainsMono#JetBrains Mono,sans-serif</FontFamily>
        <SolidColorBrush x:Key="StripCellBrush" Color="#EEEBE0" />
        <SolidColorBrush x:Key="StripBorderBrush" Color="#BFBBAE" />
        <SolidColorBrush x:Key="StripPrintedBrush" Color="#111111" />
        <SolidColorBrush x:Key="StripFieldNumberBrush" Color="#A02020" />
        <SolidColorBrush x:Key="StripDropZoneBrush" Color="#9FA0B0" />
        <SolidColorBrush x:Key="StripSeparatorWhiteBrush" Color="#F5F4EB" />
        <SolidColorBrush x:Key="StripSeparatorRedBrush" Color="#A01020" />
        <SolidColorBrush x:Key="StripSeparatorGreenBrush" Color="#1C6E2E" />
        <SolidColorBrush x:Key="StripDisconnectedBrush" Color="#E01020" />
        <SolidColorBrush x:Key="StripSelectedBorderBrush" Color="#FFD76A" />
        <!-- Aircraft List datagrid: alternating-row tint and the selected-row highlight. -->
        <SolidColorBrush x:Key="DataGridAlternateRowBrush" Color="#1AFFFFFF" />
        <SolidColorBrush x:Key="DataGridSelectedRowBrush" Color="#2D5B86" />
        <SolidColorBrush x:Key="DataGridSelectedRowHoverBrush" Color="#356CA5" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme DensityStyle="Compact" />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />

        <!-- Smaller default font for data-dense ATC display -->
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="22" />
        </Style>
        <Style Selector="DataGridCell TextBlock">
            <Setter Property="Margin" Value="4,1" />
        </Style>

        <Style Selector="DataGridRow">
            <Setter Property="MinHeight" Value="22" />
        </Style>
        <!-- Alternating row colors (toggled per-grid via the .alternating class) -->
        <Style Selector="DataGrid.alternating DataGridRow:nth-child(even) /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource DataGridAlternateRowBrush}" />
        </Style>
        <!-- Selected-row highlight (focus-independent; declared after the alternating
             style so selection wins on even rows). -->
        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource DataGridSelectedRowBrush}" />
        </Style>
        <Style Selector="DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource DataGridSelectedRowHoverBrush}" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Heading styles -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.subtle">
            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Application.Styles>
</Application>
