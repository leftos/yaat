<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Yaat.Client.Views"
        x:Class="Yaat.Client.Views.MacroImportWindow"
        x:DataType="views:MacroImportItem"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="Import Macros — Resolve Conflicts"
        Width="600"
        Height="450"
        MinWidth="500"
        MinHeight="350"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel Margin="12">

        <TextBlock DockPanel.Dock="Top"
                   Text="The following macros conflict with existing ones. Choose how to resolve each:"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Margin="0,0,0,8" />

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,8,0,0">
            <Button Content="Overwrite All"
                    x:Name="OverwriteAllButton"
                    Width="100" />
            <Button Content="Skip All"
                    x:Name="SkipAllButton"
                    Width="80" />
            <Button Content="Apply"
                    x:Name="ApplyButton"
                    Width="80" />
            <Button Content="Cancel"
                    x:Name="CancelButton"
                    Width="80" />
        </StackPanel>

        <!-- Conflict list -->
        <ScrollViewer>
            <ItemsControl x:Name="ConflictList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="views:MacroImportItem">
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8"
                                Margin="0,0,0,4">
                            <StackPanel Spacing="4">
                                <!-- Incoming macro -->
                                <TextBlock Text="{Binding IncomingDisplay}"
                                           FontWeight="SemiBold" />

                                <!-- Existing expansion -->
                                <TextBlock Text="{Binding ExistingDisplay}"
                                           Foreground="#DCDCAA"
                                           FontSize="12" />

                                <!-- Resolution controls -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                    <TextBlock Text="Action:"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <ComboBox ItemsSource="{Binding ResolutionOptions}"
                                              SelectedItem="{Binding Resolution}"
                                              Width="130"
                                              VerticalAlignment="Center" />

                                    <!-- Rename TextBox (visible only when Rename selected) -->
                                    <TextBox Text="{Binding RenamedName}"
                                             IsVisible="{Binding IsRenaming}"
                                             Watermark="New name"
                                             Width="180"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding RenameError}"
                                               IsVisible="{Binding RenameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="#FF6B6B"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
