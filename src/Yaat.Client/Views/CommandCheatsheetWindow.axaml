<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Yaat.Client.ViewModels"
        x:Class="Yaat.Client.Views.CommandCheatsheetWindow"
        x:DataType="vm:CommandCheatsheetViewModel"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="Command Cheatsheet"
        Width="780"
        Height="660"
        MinWidth="520"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button Content="Close"
                    x:Name="CloseButton"
                    Width="80"
                    IsDefault="True"
                    IsCancel="True" />
        </StackPanel>

        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="Auto,*,Auto"
              Margin="0,0,0,8">
            <TextBlock Grid.Column="0"
                       Text="Filter"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource SubtleTextBrush}" />
            <TextBox Grid.Column="1"
                     x:Name="FilterBox"
                     Watermark="verb, alias, or description..."
                     Text="{Binding FilterText}" />
        </Grid>

        <TextBlock DockPanel.Dock="Top"
                   x:Name="IntroText"
                   TextWrapping="Wrap"
                   FontSize="11"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Margin="0,0,0,8" />

        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CommandCheatsheetSectionVm">
                        <Expander Header="{Binding Category}"
                                  IsExpanded="{Binding IsExpanded}"
                                  IsVisible="{Binding IsVisible}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Margin="0,0,0,4"
                                  Padding="8,4">
                            <StackPanel Spacing="0">
                                <ItemsControl ItemsSource="{Binding VisibleRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CommandCheatsheetRowVm">
                                            <Grid ColumnDefinitions="120,90,*"
                                                  Margin="0,1">
                                                <StackPanel Grid.Column="0"
                                                            Orientation="Horizontal"
                                                            Spacing="3">
                                                    <TextBlock Text="{Binding Verb}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="*"
                                                               IsVisible="{Binding IsGlobal}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Aliases}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                           FontSize="11" />
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            Spacing="6">
                                                    <TextBlock Text="{Binding Description}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Examples}"
                                                               IsVisible="{Binding Examples, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               FontSize="11" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding Notes}"
                                              Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <TextBlock Text="{Binding}"
                                                       TextWrapping="Wrap"
                                                       FontSize="11"
                                                       FontStyle="Italic"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
