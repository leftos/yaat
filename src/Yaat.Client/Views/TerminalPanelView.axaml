<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             x:Class="Yaat.Client.Views.TerminalPanelView">

    <DockPanel>

        <!-- Header -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*,Auto,Auto"
              Margin="4,2">
            <TextBlock Grid.Column="0"
                       Text="Terminal"
                       FontWeight="Bold"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SubtleTextBrush}" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0">
                <ToggleButton IsChecked="{Binding ShowCommandEntries}"
                              Content="CMD"
                              FontSize="10"
                              Padding="4,1"
                              Foreground="White" />
                <ToggleButton IsChecked="{Binding ShowResponseEntries}"
                              Content="RSP"
                              FontSize="10"
                              Padding="4,1"
                              Foreground="LightGray" />
                <ToggleButton IsChecked="{Binding ShowSystemEntries}"
                              Content="SYS"
                              FontSize="10"
                              Padding="4,1"
                              Foreground="Gray" />
                <ToggleButton IsChecked="{Binding ShowSayEntries}"
                              Content="SAY"
                              FontSize="10"
                              Padding="4,1"
                              Foreground="Green" />
                <ToggleButton IsChecked="{Binding ShowWarningEntries}"
                              Content="WRN"
                              FontSize="10"
                              Padding="4,1"
                              Foreground="Orange" />
                <ToggleButton IsChecked="{Binding ShowErrorEntries}"
                              Content="ERR"
                              FontSize="10"
                              Padding="4,1"
                              Foreground="Red" />
                <ToggleButton IsChecked="{Binding ShowChatEntries}"
                              Content="CHAT"
                              FontSize="10"
                              Padding="4,1"
                              Foreground="Cyan" />
            </StackPanel>
            <Button Grid.Column="2"
                    Content="{Binding IsTerminalDocked,
                        Converter={x:Static vm:DockButtonConverter.Instance}}"
                    Command="{Binding ToggleTerminalDockCommand}"
                    FontSize="11"
                    Padding="6,2" />
        </Grid>

        <!-- Scrolling terminal text (read-only, colorized per entry kind) -->
        <ae:TextEditor x:Name="TerminalEditor"
                       IsReadOnly="True"
                       ShowLineNumbers="False"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="12"
                       WordWrap="True"
                       Background="#1A1A1E"
                       Foreground="White"
                       Padding="4"
                       HorizontalScrollBarVisibility="Disabled"
                       VerticalScrollBarVisibility="Auto">
            <ae:TextEditor.Options>
                <ae:TextEditorOptions AllowScrollBelowDocument="False" />
            </ae:TextEditor.Options>
        </ae:TextEditor>

    </DockPanel>
</UserControl>
