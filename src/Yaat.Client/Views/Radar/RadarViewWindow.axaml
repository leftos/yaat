<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:radar="using:Yaat.Client.Views.Radar"
        xmlns:views="using:Yaat.Client.Views"
        x:Class="Yaat.Client.Views.Radar.RadarViewWindow"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="Radar View">

    <DockPanel>
        <views:RestartNotificationView DockPanel.Dock="Top" />
        <radar:RadarView DataContext="{Binding Radar}" />
    </DockPanel>

</Window>
