<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             xmlns:models="using:Yaat.Client.Models"
             x:Class="Yaat.Client.Views.DataGridView"
             x:DataType="vm:MainViewModel">

    <LayoutTransformControl>
    <LayoutTransformControl.LayoutTransform>
        <ScaleTransform ScaleX="{Binding DataGridScale}" ScaleY="{Binding DataGridScale}" />
    </LayoutTransformControl.LayoutTransform>
    <DockPanel>
    <TextBox x:Name="SearchBox"
             DockPanel.Dock="Top"
             PlaceholderText="Search aircraft (callsign, type, squawk, dep, dest...)"
             Text="{Binding AircraftFilterText, Mode=TwoWay}"
             Margin="4,4,4,2"
             FontSize="12" />
    <DataGrid x:Name="AircraftGrid"
              ItemsSource="{Binding AircraftView}"
              Classes.alternating="{Binding DataGridAlternatingRowColor}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              GridLinesVisibility="Horizontal"
              CanUserResizeColumns="True"
              CanUserReorderColumns="True"
              SelectionMode="Single"
              RowDetailsVisibilityMode="VisibleWhenSelected">
        <DataGrid.RowDetailsTemplate>
            <DataTemplate x:DataType="models:AircraftModel">
                <Border Padding="12,6"
                        Background="#0AFFFFFF"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="0,1">
                    <StackPanel Spacing="3">
                        <!-- Phases -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding HasPhases}">
                            <TextBlock Text="Phases"
                                       Width="80"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding PhaseSequenceDisplay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" />
                        </StackPanel>
                        <!-- Pattern -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding HasPattern}">
                            <TextBlock Text="Pattern"
                                       Width="80"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding PatternDisplay}"
                                       FontSize="12" />
                        </StackPanel>
                        <!-- Clearance -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding HasClearance}">
                            <TextBlock Text="Clearance"
                                       Width="80"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding ClearanceDisplay}"
                                       Foreground="LightGreen"
                                       FontSize="12" />
                        </StackPanel>
                        <!-- Flight Plan -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding HasFlightPlan}">
                            <TextBlock Text="FP"
                                       Width="80"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding FlightPlanDisplay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" />
                        </StackPanel>
                        <!-- Remarks -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding HasRemarks}">
                            <TextBlock Text="Remarks"
                                       Width="80"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding Remarks}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12" />
                        </StackPanel>
                        <!-- Navigation Route (only when divergent from filed route) -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding ShowNavRoute}">
                            <TextBlock Text="Nav"
                                       Width="80"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding NavigationRouteDisplay}"
                                       FontFamily="{StaticResource MonoFont}"
                                       Foreground="SkyBlue"
                                       FontSize="12" />
                        </StackPanel>
                        <!-- Pending Commands -->
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding PendingCommands, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="Pending"
                                       Width="80"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding PendingCommands}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </DataGrid.RowDetailsTemplate>
        <DataGrid.Columns>
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Callsign" Binding="{Binding Callsign}" Width="Auto" />
            <DataGridTemplateColumn x:DataType="models:AircraftModel" Header="Info" Width="Auto" SortMemberPath="SmartStatus">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate x:DataType="models:AircraftModel">
                        <StackPanel Orientation="Horizontal" Margin="4,0" Spacing="4" VerticalAlignment="Center">
                            <Border IsVisible="{Binding HasCfrBadge}" BorderBrush="{Binding CfrBadgeExpired, Converter={x:Static vm:CfrBadgeBrushConverter.Instance}}" BorderThickness="1" CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CfrBadge}" Foreground="{Binding CfrBadgeExpired, Converter={x:Static vm:CfrBadgeBrushConverter.Instance}}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding SmartStatus}" Foreground="{Binding SmartStatusSeverity, Converter={x:Static vm:SmartStatusSeverityBrushConverter.Instance}}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="RPO" Binding="{Binding AssignedTo}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Status" Binding="{Binding StatusDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Owner" Binding="{Binding OwnerDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="HO" Binding="{Binding HandoffDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="SP1" Binding="{Binding Scratchpad1}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="SP2" Binding="{Binding Scratchpad2}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="TA" Binding="{Binding TempAltDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Phase" Binding="{Binding CurrentPhase}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Clnc" Binding="{Binding ClearanceShorthand}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Rwy" Binding="{Binding AssignedRunway, Converter={x:Static vm:RunwayDisplayConverter.Instance}}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Apch" Binding="{Binding ActiveApproachId}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="EApch" Binding="{Binding ExpectedApproachDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Type" Binding="{Binding AircraftType}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Name" Binding="{Binding AircraftTypeName}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Rules" Binding="{Binding FlightRules}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Dep" Binding="{Binding Departure}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Dest" Binding="{Binding Destination}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Fix" Binding="{Binding AsdexFix}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Route" Binding="{Binding Route}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="P.Alt" Binding="{Binding CruiseAltitudeDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Remarks" Binding="{Binding Remarks}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Squawk" Binding="{Binding BeaconCode, StringFormat=\{0:D4\}}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Hdg" Binding="{Binding HeadingDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Alt" Binding="{Binding Altitude, StringFormat=\{0:F0\}}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="IAS" Binding="{Binding IndicatedAirspeed, StringFormat=\{0:F0\}}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Mach" Binding="{Binding MachDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="GS" Binding="{Binding GroundSpeed, StringFormat=\{0:F0\}}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Wind" Binding="{Binding Wind}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="VS" Binding="{Binding VerticalSpeed, StringFormat=\{0:F0\}}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="AHdg" Binding="{Binding AssignedHeadingDisplay}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="AAlt" Binding="{Binding AssignedAltitude, StringFormat=\{0:F0\}}" Width="Auto" />
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="ASpd" Binding="{Binding AssignedSpeedDisplay}" Width="Auto" />
            <DataGridTemplateColumn x:DataType="models:AircraftModel" Width="Auto" SortMemberPath="DistanceFromFix">
                <DataGridTemplateColumn.Header>
                    <TextBlock Text="{Binding $parent[Window].((vm:MainViewModel)DataContext).DistanceReferenceFix, StringFormat='Dist ({0})', FallbackValue='Dist'}" x:Name="DistanceHeader" />
                </DataGridTemplateColumn.Header>
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate x:DataType="models:AircraftModel">
                        <TextBlock Text="{Binding DistanceFromFix, StringFormat='\{0:F1\}'}" Margin="4,0" VerticalAlignment="Center" />
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn x:DataType="models:AircraftModel" Header="Pending Cmds" Binding="{Binding PendingCommands}" Width="Auto" />
        </DataGrid.Columns>
    </DataGrid>
    </DockPanel>
    </LayoutTransformControl>

</UserControl>
