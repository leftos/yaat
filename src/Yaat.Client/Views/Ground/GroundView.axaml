<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ground="using:Yaat.Client.Views.Ground"
             xmlns:vm="using:Yaat.Client.ViewModels"
             x:Class="Yaat.Client.Views.Ground.GroundView"
             x:DataType="vm:GroundViewModel">

    <UserControl.Styles>
        <Style Selector="Button.gnd-filter">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="BorderBrush" Value="#444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.gnd-filter:pointerover">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
        <Style Selector="Button.gnd-filter.active">
            <Setter Property="Background" Value="#44FFFFFF" />
            <Setter Property="Foreground" Value="#DDD" />
            <Setter Property="BorderBrush" Value="#888" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <ground:GroundCanvas x:Name="Canvas"
                             Layout="{Binding Layout}"
                             SelectedAircraft="{Binding SelectedAircraft}"
                             ActiveRoute="{Binding ActiveRoute}"
                             PreviewRoute="{Binding PreviewRoute}"
                             DrawnRoutePreview="{Binding DrawnRoutePreview}"
                             DrawHoverPreview="{Binding DrawHoverPreview}"
                             IsDrawingRoute="{Binding IsDrawingRoute}"
                             DrawWaypoints="{Binding DrawWaypoints}"
                             AirportCenterLat="{Binding AirportCenterLat}"
                             AirportCenterLon="{Binding AirportCenterLon}"
                             AirportElevation="{Binding AirportElevation}"
                             Aircraft="{Binding $parent[Window].DataContext.Aircraft}"
                             WeatherInfo="{Binding WeatherInfo}"
                             ShowRunwayLabels="{Binding ShowRunwayLabels}"
                             ShowTaxiwayLabels="{Binding ShowTaxiwayLabels}"
                             ShowHoldShortLabels="{Binding ShowHoldShortLabels}"
                             ShowParkingLabels="{Binding ShowParkingLabels}"
                             ShowSpotLabels="{Binding ShowSpotLabels}"
                             ShownTaxiRoutes="{Binding ShownTaxiRoutes}"
                             IsPanZoomLocked="{Binding IsPanZoomLocked}"
                             ViewCenterLat="{Binding ViewCenterLat, Mode=TwoWay}"
                             ViewCenterLon="{Binding ViewCenterLon, Mode=TwoWay}"
                             ViewZoom="{Binding ViewZoom, Mode=TwoWay}"
                             ViewRotation="{Binding ViewRotation, Mode=TwoWay}" />

        <!-- Label filter bar -->
        <StackPanel Orientation="Horizontal" Spacing="2"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,6,6,0"
                    IsVisible="{Binding Layout, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="Labels:" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                       FontFamily="{StaticResource MonoFont}" />
            <Button Classes="gnd-filter" Classes.active="{Binding ShowRunwayLabels}" Content="RWY" Click="OnToggleRunwayLabels" />
            <Button Classes="gnd-filter" Classes.active="{Binding ShowTaxiwayLabels}" Content="TWY" Click="OnToggleTaxiwayLabels" />
            <Button Classes="gnd-filter" Classes.active="{Binding ShowHoldShortLabels}" Content="HS" Click="OnToggleHoldShortLabels" />
            <Button Classes="gnd-filter" Classes.active="{Binding ShowParkingLabels}" Content="PARK" Click="OnToggleParkingLabels" />
            <Button Classes="gnd-filter" Classes.active="{Binding ShowSpotLabels}" Content="SPOT" Click="OnToggleSpotLabels" />
            <Border Width="1" Background="#555" Margin="4,2" />
            <Button Classes="gnd-filter" Classes.active="{Binding IsPanZoomLocked}" Content="{Binding IsPanZoomLocked, Converter={x:Static ground:GroundView.BoolToLockLabel}}" Click="OnToggleLock" />
        </StackPanel>

        <!-- No layout message -->
        <TextBlock Text="No airport layout loaded"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding Layout, Converter={x:Static ObjectConverters.IsNull}}" />

        <!-- Draw route status overlay -->
        <Border IsVisible="{Binding IsDrawingRoute}"
                Background="#CC000000" Padding="8,4"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                CornerRadius="4" Margin="0,8">
            <TextBlock Text="Click nodes to add waypoints. Right-click node to finish. Backspace to undo. Esc to cancel." Foreground="White" FontSize="12"/>
        </Border>

        <!-- Custom taxi route input overlay -->
        <Border x:Name="TaxiInputOverlay"
                IsVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,12"
                Padding="8,6"
                CornerRadius="4"
                Background="#DD1E1E2E"
                BorderBrush="#555"
                BorderThickness="1">
            <TextBox x:Name="TaxiInputBox"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="14"
                     MinWidth="300"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="White"
                     CaretBrush="White" />
        </Border>
    </Panel>

</UserControl>
