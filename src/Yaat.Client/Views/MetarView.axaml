<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             x:Class="Yaat.Client.Views.MetarView"
             x:DataType="vm:MainViewModel">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,5"
                Background="#0AFFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="METAR" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ActiveWeatherName}"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="8,8"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Text="No weather or scenario loaded."
                   IsVisible="{Binding !Metars.Count}" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Metars}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:MetarEntry">
                        <Border Padding="8,6"
                                BorderBrush="#14FFFFFF"
                                BorderThickness="0,0,0,1">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding StationId}"
                                           FontWeight="SemiBold"
                                           FontSize="{DynamicResource UiFontSizeSubtle}"
                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                <SelectableTextBlock Text="{Binding Raw}"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Consolas,Menlo,monospace" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
