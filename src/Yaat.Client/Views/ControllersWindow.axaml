<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Yaat.Client.ViewModels"
        x:Class="Yaat.Client.Views.ControllersWindow"
        x:DataType="vm:MainViewModel"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="Controllers">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,6"
                Background="#0AFFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Online Controllers"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Refresh"
                        Command="{Binding RefreshOnlineControllersCommand}" />
            </Grid>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="8,8"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Text="No controllers online. Load a scenario or wait for a CRC controller to connect."
                   TextWrapping="Wrap"
                   IsVisible="{Binding !OnlineControllers.Count}" />

        <DataGrid x:CompileBindings="False"
                  ItemsSource="{Binding OnlineControllers}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Callsign" Binding="{Binding Callsign}" Width="Auto" />
                <DataGridTextColumn Header="Freq" Binding="{Binding Frequency}" Width="Auto" />
                <DataGridTextColumn Header="TCP" Binding="{Binding Tcp}" Width="Auto" />
                <DataGridTextColumn Header="Position" Binding="{Binding RadioName}" Width="*" />
                <DataGridTextColumn Header="Facility" Binding="{Binding FacilityId}" Width="Auto" />
                <DataGridTextColumn Header="Controller" Binding="{Binding RealName}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="Auto" />
                <DataGridTextColumn Header="Source" Binding="{Binding SourceText}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</Window>
