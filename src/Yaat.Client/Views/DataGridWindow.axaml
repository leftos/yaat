<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Yaat.Client.ViewModels"
        xmlns:views="using:Yaat.Client.Views"
        x:Class="Yaat.Client.Views.DataGridWindow"
        x:DataType="vm:MainViewModel"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="{Binding AircraftListTitle, FallbackValue='Aircraft List'}">

    <views:DataGridView x:Name="PopOutDataGridView" />

</Window>
