<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Yaat.Client.Views.SpeechDebugWindow"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="Speech Recognition Debug"
        Width="820"
        Height="560"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0"
                    Spacing="8">
            <Button x:Name="ClearButton" Content="Clear history" />
            <Button x:Name="CloseButton" Content="Close" Width="80" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top"
                   Text="Shows the 20 most recent push-to-talk sessions. Most recent at the top. Click a session to see the raw transcript and canonical command output."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   FontSize="11"
                   Margin="0,0,0,8" />

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="SessionsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A2E"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="8"
                                Margin="0,0,0,6">
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TimestampUtc, StringFormat='{}{0:HH:mm:ss}'}"
                                               FontFamily="Consolas,monospace"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Outcome}"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalElapsedMs, StringFormat='total {0} ms'}"
                                               FontFamily="Consolas,monospace"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="Audio:"
                                               Width="90"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AudioDurationSeconds, StringFormat='{}{0:F2} s'}"
                                               FontFamily="Consolas,monospace"
                                               FontSize="11" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="Transcribe:"
                                               Width="90"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TranscribeElapsedMs, StringFormat='{}{0} ms'}"
                                               FontFamily="Consolas,monospace"
                                               FontSize="11" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="Map:"
                                               Width="90"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding MapElapsedMs, StringFormat='{}{0} ms'}"
                                               FontFamily="Consolas,monospace"
                                               FontSize="11" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="Transcript:"
                                               Width="90"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Transcript, Mode=OneWay}"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontFamily="Consolas,monospace"
                                             FontSize="11"
                                             Padding="0" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="Canonical:"
                                               Width="90"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding CanonicalCommand, Mode=OneWay}"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontFamily="Consolas,monospace"
                                             FontSize="11"
                                             Padding="0" />
                                    <TextBlock Grid.Column="2"
                                               Text="(LLM fallback)"
                                               IsVisible="{Binding UsedLlmFallback}"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11"
                                               Margin="8,0,0,0" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*"
                                      IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Grid.Column="0"
                                               Text="Error:"
                                               Width="90"
                                               Foreground="#FF6B6B"
                                               FontSize="11" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding ErrorMessage, Mode=OneWay}"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="#FF6B6B"
                                             FontFamily="Consolas,monospace"
                                             FontSize="11"
                                             Padding="0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
