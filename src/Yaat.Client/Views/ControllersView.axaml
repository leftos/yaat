<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             xmlns:svc="using:Yaat.Client.Services"
             x:Class="Yaat.Client.Views.ControllersView"
             x:DataType="vm:MainViewModel">

    <UserControl.Styles>
        <!-- Inactive / standby controllers are dimmed, as in CRC. -->
        <Style Selector="TextBlock.dimmed">
            <Setter Property="Foreground" Value="#6E7479" />
        </Style>
        <!-- Selectable controller rows span the full width. -->
        <Style Selector="ListBox.controllers ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="16,1,8,1" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,5"
                Background="#0AFFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Controllers"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Refresh"
                        Padding="8,2"
                        Command="{Binding RefreshOnlineControllersCommand}" />
            </Grid>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="8,8"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Text="No controllers online. Load a scenario or wait for a CRC controller to connect."
                   TextWrapping="Wrap"
                   IsVisible="{Binding !OnlineControllers.Count}" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding ControllerGroups}" Margin="0,2,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ControllerGroupVm">
                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="0"
                                  Margin="2,2,2,0">
                            <Expander.Header>
                                <TextBlock Text="{Binding Header}"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           Foreground="#2DD4BF" />
                            </Expander.Header>
                            <ListBox Classes="controllers"
                                     ItemsSource="{Binding Controllers}"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="svc:OnlineControllerDto">
                                        <Grid ColumnDefinitions="48,*,Auto" ToolTip.Tip="{Binding Tooltip}">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding HandoffId}"
                                                       Foreground="White"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="White"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Frequency}"
                                                       Margin="12,0,0,0"
                                                       Foreground="White"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
