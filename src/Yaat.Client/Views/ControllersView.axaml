<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             xmlns:svc="using:Yaat.Client.Services"
             x:Class="Yaat.Client.Views.ControllersView"
             x:DataType="vm:MainViewModel">

    <UserControl.Styles>
        <!-- Inactive / standby controllers are dimmed, as in CRC. -->
        <Style Selector="TextBlock.dimmed">
            <Setter Property="Foreground" Value="#6E7479" />
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,5"
                Background="#0AFFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Controllers"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Refresh"
                        Padding="8,2"
                        Command="{Binding RefreshOnlineControllersCommand}" />
            </Grid>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="8,8"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Text="No controllers online. Load a scenario or wait for a CRC controller to connect."
                   TextWrapping="Wrap"
                   IsVisible="{Binding !OnlineControllers.Count}" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding ControllerGroups}" Margin="0,2,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ControllerGroupVm">
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Text="{Binding Header}"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Foreground="#E0A33A"
                                       Margin="8,0,8,2" />
                            <ItemsControl ItemsSource="{Binding Controllers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="svc:OnlineControllerDto">
                                        <Grid ColumnDefinitions="48,*,Auto"
                                              Margin="16,1,8,1"
                                              ToolTip.Tip="{Binding Tooltip}">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding HandoffId}"
                                                       Foreground="#4FC3F7"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#4FC3F7"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Frequency}"
                                                       Margin="12,0,0,0"
                                                       Foreground="#9AA0A6"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
