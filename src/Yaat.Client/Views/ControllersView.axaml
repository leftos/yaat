<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             xmlns:svc="using:Yaat.Client.Services"
             x:Class="Yaat.Client.Views.ControllersView"
             x:DataType="vm:MainViewModel">

    <UserControl.Styles>
        <!-- Inactive / standby controllers are dimmed, as in CRC. -->
        <Style Selector="TextBlock.dimmed">
            <Setter Property="Foreground" Value="#6E7479" />
        </Style>
        <!-- Selectable controller rows span the full width. -->
        <Style Selector="ListBox.controllers ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="16,1,8,1" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <!-- Flat, full-width facility header button. -->
        <Style Selector="Button.grouphdr">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.grouphdr:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,5"
                Background="#0AFFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Controllers"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Refresh"
                        Padding="8,2"
                        Command="{Binding RefreshOnlineControllersCommand}" />
            </Grid>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="8,8"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Text="No controllers online. Load a scenario or wait for a CRC controller to connect."
                   TextWrapping="Wrap"
                   IsVisible="{Binding !OnlineControllers.Count}" />

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ControllerGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ControllerGroupVm">
                        <StackPanel>
                            <Button Classes="grouphdr" Command="{Binding ToggleExpandedCommand}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Header}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Foreground="#2DD4BF" />
                                    <TextBlock Grid.Column="1"
                                               Text="▾"
                                               Foreground="#2DD4BF"
                                               IsVisible="{Binding IsExpanded}" />
                                    <TextBlock Grid.Column="1"
                                               Text="▸"
                                               Foreground="#2DD4BF"
                                               IsVisible="{Binding !IsExpanded}" />
                                </Grid>
                            </Button>
                            <ListBox Classes="controllers"
                                     ItemsSource="{Binding Controllers}"
                                     IsVisible="{Binding IsExpanded}"
                                     Background="Transparent"
                                     SelectionMode="Single"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="svc:OnlineControllerDto">
                                        <Grid ColumnDefinitions="48,*,Auto" ToolTip.Tip="{Binding Tooltip}">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding HandoffId}"
                                                       Foreground="White"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="White"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Frequency}"
                                                       Margin="12,0,0,0"
                                                       Foreground="White"
                                                       Classes.dimmed="{Binding !IsActive}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
