<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Yaat.Client.ViewModels"
        x:Class="Yaat.Client.Views.MetarWindow"
        x:DataType="vm:MainViewModel"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="METAR">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="8,6"
                Background="#0AFFFFFF"
                BorderBrush="#1AFFFFFF"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="METAR" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ActiveWeatherName}"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <TextBlock DockPanel.Dock="Bottom"
                   Margin="8,8"
                   Foreground="{DynamicResource SubtleTextBrush}"
                   Text="No weather loaded."
                   IsVisible="{Binding !Metars.Count}" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Metars}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:MetarEntry">
                        <Border Padding="8,6"
                                BorderBrush="#14FFFFFF"
                                BorderThickness="0,0,0,1">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding StationId}"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                <SelectableTextBlock Text="{Binding Raw}"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Consolas,Menlo,monospace" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</Window>
