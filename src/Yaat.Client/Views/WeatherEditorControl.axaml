<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Yaat.Client.ViewModels"
    x:Class="Yaat.Client.Views.WeatherEditorControl"
    x:DataType="vm:WeatherPeriodViewModel">

    <ScrollViewer>
    <StackPanel Spacing="12">

        <!-- Precipitation -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Precip:" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding PrecipitationOptions}"
                      SelectedItem="{Binding Precipitation}"
                      Width="100">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding TargetNullValue='(none)'}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- Wind Layers -->
        <TextBlock Text="Wind Layers" FontWeight="Bold" Margin="0,4,0,0" />
        <DataGrid ItemsSource="{Binding WindLayers}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  MinHeight="80"
                  MaxHeight="260">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Alt (ft)" Binding="{Binding Altitude}" Width="80" />
                <DataGridTextColumn Header="Dir (°)" Binding="{Binding Direction}" Width="70" />
                <DataGridTextColumn Header="Speed (kt)" Binding="{Binding Speed}" Width="80" />
                <DataGridTextColumn Header="Gusts (kt)" Binding="{Binding Gusts}" Width="80" />
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:WindLayerRow">
                            <Button Content="X"
                                    Command="{Binding $parent[UserControl].DataContext.RemoveLayerCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="4,1"
                                    FontSize="11"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Add Layer"
                Command="{Binding AddLayerCommand}"
                HorizontalAlignment="Left" />

        <!-- METARs -->
        <TextBlock Text="METARs" FontWeight="Bold" Margin="0,4,0,0" />
        <ItemsControl ItemsSource="{Binding Metars}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:MetarRow">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                        <TextBox Grid.Column="0"
                                 Text="{Binding Text}"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="11" />
                        <Button Grid.Column="1"
                                Content="X"
                                Command="{Binding $parent[UserControl].DataContext.RemoveMetarCommand}"
                                CommandParameter="{Binding}"
                                Padding="4,1"
                                FontSize="11"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="Add METAR"
                Command="{Binding AddMetarCommand}"
                HorizontalAlignment="Left" />

    </StackPanel>
    </ScrollViewer>

</UserControl>
