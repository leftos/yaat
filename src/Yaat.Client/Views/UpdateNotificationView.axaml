<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             x:Class="Yaat.Client.Views.UpdateNotificationView"
             x:DataType="vm:MainViewModel">
    <Border Background="#1A3A5C"
            BorderBrush="#2A5A8C"
            BorderThickness="0,1,0,0"
            Padding="8,4"
            IsVisible="{Binding IsUpdateAvailable}">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
            <!-- Status text -->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="12">
                <TextBlock.Text>
                    <MultiBinding StringFormat="YAAT {0} is available.">
                        <Binding Path="UpdateVersion" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <!-- Progress bar (visible during download) -->
            <ProgressBar Grid.Column="1"
                         Width="120"
                         Height="14"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding UpdateProgress}"
                         IsVisible="{Binding IsDownloadingUpdate}"
                         VerticalAlignment="Center"
                         Margin="8,0" />

            <!-- Update button -->
            <Button Grid.Column="2"
                    Content="Update Now"
                    FontSize="11"
                    Padding="8,2"
                    Margin="4,0"
                    Command="{Binding UpdateNowCommand}"
                    IsVisible="{Binding !IsDownloadingUpdate}" />

            <!-- Dismiss button -->
            <Button Grid.Column="3"
                    Content="Later"
                    FontSize="11"
                    Padding="8,2"
                    Margin="4,0"
                    Command="{Binding DismissUpdateCommand}"
                    IsVisible="{Binding !IsDownloadingUpdate}" />
        </Grid>
    </Border>
</UserControl>
