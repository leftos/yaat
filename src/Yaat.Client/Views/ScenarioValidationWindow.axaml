<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Yaat.Client.Views.ScenarioValidationWindow"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="Scenario Validation Report"
        Width="950"
        Height="600"
        MinWidth="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel Margin="12">

        <!-- Bottom: buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button Content="Copy Report"
                    x:Name="CopyReportButton"
                    Width="100" />
            <Button Content="Close"
                    x:Name="CloseButton"
                    Width="80" />
        </StackPanel>

        <!-- Header: summary stats -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="16"
                    Margin="0,0,0,8">
            <TextBlock x:Name="SummaryText"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="StatsText"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Content: DataGrid of failures -->
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       x:Name="FailuresHeader"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <DataGrid x:Name="FailuresGrid"
                      AutoGenerateColumns="False"
                      GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Scenario" Binding="{Binding ScenarioName}" Width="250" IsReadOnly="True" />
                    <DataGridTextColumn Header="Aircraft" Binding="{Binding AircraftId}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="300" IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

    </DockPanel>
</Window>
