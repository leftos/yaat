<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Yaat.Client.ViewModels"
        x:Class="Yaat.Client.Views.SettingsWindow"
        Icon="avares://Yaat.Client/Resources/icon.png"
        Title="Settings">

    <Window.Resources>
        <vm:HexColorConverter x:Key="HexColorConverter" />
    </Window.Resources>

    <Design.DataContext>
        <vm:SettingsViewModel />
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- Bottom buttons -->
        <DockPanel DockPanel.Dock="Bottom"
                   Margin="0,12,0,0">
            <Button Content="Reset to Defaults"
                    Command="{Binding ResetCommandsToDefaultsCommand}"
                    DockPanel.Dock="Left"
                    IsVisible="{Binding IsSelected, ElementName=CommandsTab}" />
            <Button Content="Clear All Macros"
                    Command="{Binding ClearAllMacrosCommand}"
                    DockPanel.Dock="Left"
                    IsVisible="{Binding IsSelected, ElementName=MacrosTab}"
                    Margin="8,0,0,0" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Save"
                        x:Name="SaveButton"
                        Width="80" />
                <Button Content="Cancel"
                        x:Name="CancelButton"
                        Width="80" />
            </StackPanel>
        </DockPanel>

        <!-- Tab content -->
        <TabControl>

            <!-- Identity tab -->
            <TabItem Header="Identity">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="12">
                        <TextBlock Text="Your identity and CID come from VATSIM sign-in when you connect."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Initials (2 letters):"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <TextBox Text="{Binding UserInitials}"
                                     MaxLength="2"
                                     Watermark="e.g. AB"
                                     Width="80"
                                     HorizontalAlignment="Left" />
                            <TextBlock Text="Shown in the terminal panel so other RPOs can see who issued each command."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="ARTCC:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <TextBlock Text="Set automatically from your VATSIM/VATUSA profile when you sign in."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Scenarios tab -->
            <TabItem Header="Scenarios">
                <ScrollViewer>
                <StackPanel Margin="12" Spacing="12">
                    <TextBlock Text="These are your default preferences, applied when you load a scenario. Once in a session, use the gear icon in the command bar to change the active settings for all RPOs."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="11"
                               FontStyle="Italic"
                               Margin="0,0,0,4" />
                    <StackPanel Spacing="4">
                        <CheckBox Content="Solo training mode"
                                  IsChecked="{Binding SoloTrainingMode}" />
                        <TextBlock Text="Aircraft make their own pilot transmissions and typed natural-language ATC commands can be mapped to YAAT commands after normal parsing fails."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Margin="28,0,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Pilot go-around probability (default)"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,2" />
                        <TextBlock Text="Per-approach chance that AI aircraft in solo training spontaneously go around on final. Set per-scenario in the scenario setup dialog or the session settings flyout; this value seeds new scenarios that have no saved override."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="12,0,0,0">
                            <Slider Value="{Binding SoloGoAroundProbabilityPercent}"
                                    Minimum="0"
                                    Maximum="100"
                                    TickFrequency="5"
                                    Width="240"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SoloGoAroundProbabilityPercent, StringFormat='{}{0}%'}"
                                       VerticalAlignment="Center"
                                       Width="48"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <CheckBox Content="Auto-accept handoffs to unattended positions"
                                  IsChecked="{Binding AutoAcceptEnabled}" />
                        <StackPanel Spacing="4"
                                    IsVisible="{Binding AutoAcceptEnabled}"
                                    Margin="28,0,0,0">
                            <TextBlock Text="Delay (seconds):"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <NumericUpDown Value="{Binding AutoAcceptDelaySeconds}"
                                           Minimum="0"
                                           Maximum="60"
                                           Increment="1"
                                           Width="120"
                                           HorizontalAlignment="Left" />
                            <TextBlock Text="Handoffs are automatically accepted after this delay. Set to 0 for immediate acceptance."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Command run delay (seconds):"
                                   Foreground="{DynamicResource SubtleTextBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Min" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" />
                            <NumericUpDown Value="{Binding CommandRunDelayMinSeconds}"
                                           Minimum="0"
                                           Maximum="60"
                                           Increment="1"
                                           Width="110" />
                            <TextBlock Text="Max" VerticalAlignment="Center" Foreground="{DynamicResource SubtleTextBrush}" />
                            <NumericUpDown Value="{Binding CommandRunDelayMaxSeconds}"
                                           Minimum="0"
                                           Maximum="60"
                                           Increment="1"
                                           Width="110" />
                        </StackPanel>
                        <TextBlock Text="Simulates pilot reaction / FMC setup time: commands take effect after a random delay in this range (set both equal for a fixed delay). A few seconds (e.g. 3-8) is realistic. Frequency changes are never delayed. Set max to 0 to disable."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Default Auto-Delete:"
                                   Foreground="{DynamicResource SubtleTextBrush}" />
                        <ComboBox ItemsSource="{Binding AutoDeleteOptions}"
                                  SelectedIndex="{Binding SelectedAutoDeleteIndex}"
                                  Width="220"
                                  HorizontalAlignment="Left" />
                        <TextBlock Text="Your default preference, applied when you load a scenario. Other RPOs can change the active setting via the session dropdown in the command bar."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <CheckBox Content="Validate DCT fixes against programmed route"
                                  IsChecked="{Binding ValidateDctFixes}" />
                        <TextBlock Text="When enabled, DCT to a fix not in the aircraft's route or expected approach is rejected. Use DCTF to override. Requires issuing EAPP (Expect Approach) to program approach fixes."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Margin="28,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="Simulation Shortcuts"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Auto-clear aircraft to land" FontWeight="SemiBold" Margin="0,0,0,2" />
                        <TextBlock Text="Aircraft on final approach are automatically cleared to land without requiring a CLAND command. Configure per position type." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="12,0,0,0">
                            <CheckBox Content="GND" IsChecked="{Binding AutoClearedToLandGnd}" />
                            <CheckBox Content="TWR" IsChecked="{Binding AutoClearedToLandTwr}" />
                            <CheckBox Content="APP" IsChecked="{Binding AutoClearedToLandApp}" />
                            <CheckBox Content="CTR" IsChecked="{Binding AutoClearedToLandCtr}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <CheckBox Content="Aircraft cross runways automatically"
                                  IsChecked="{Binding AutoCrossRunway}" />
                        <TextBlock Text="Taxiing aircraft cross runways without stopping. No CROSS command needed. Hold-short commands and destination runway hold-shorts still apply."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Margin="28,0,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <CheckBox Content="Auto pull-up to hold short of parallel runway after landing"
                                  IsChecked="{Binding AutoPullUpToParallel}" />
                        <TextBlock Text="After exiting the landing runway, aircraft automatically pull up to the parallel runway hold-short without a TAXI command. On by default."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Margin="28,0,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <CheckBox Content="Show sim-initiated pilot transmissions as pilot speech (RPO mode)"
                                  IsChecked="{Binding RpoShowPilotSpeech}" />
                        <TextBlock Text="Renders auto-generated pilot reports (traffic in sight, holding short, going around, midfield/short-final reminders, etc.) as green pilot speech with the spelled-out spoken form. Default off — preserves the orange Warning text."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Margin="28,0,0,0" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <CheckBox Content="Audible alert on pilot transmissions"
                                  IsChecked="{Binding RpoPilotSpeechAudibleAlert}" />
                        <TextBlock Text="Plays a short ding when a sim-initiated pilot transmission appears. Independent of the visual setting above. Does not fire on AS-prefix SAY commands you typed yourself."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Margin="28,0,0,0" />
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Display tab -->
            <TabItem Header="Display">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="12">
                        <TextBlock Text="Font Sizes"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="200,120" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Aircraft List"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding DataGridFontSize}"
                                           Minimum="8" Maximum="24" Increment="1" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Radar Datablock"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding RadarDatablockFontSize}"
                                           Minimum="8" Maximum="24" Increment="1" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Radar Tag Flyouts"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding RadarFlyoutFontSize}"
                                           Minimum="8" Maximum="24" Increment="1" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ground Datablock"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding GroundDatablockFontSize}"
                                           Minimum="8" Maximum="24" Increment="1" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Ground Labels (taxi/runway/node)"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding GroundLabelFontSize}"
                                           Minimum="8" Maximum="24" Increment="1" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Terminal (output + input)"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding TerminalFontSize}"
                                           Minimum="8" Maximum="24" Increment="1" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Interface (tabs, buttons, lists)"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="6" Grid.Column="1" Value="{Binding InterfaceFontSize}"
                                           Minimum="8" Maximum="24" Increment="1" />
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Strips Zoom %"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="7" Grid.Column="1" Value="{Binding StripsZoomPercent}"
                                           Minimum="50" Maximum="200" Increment="10" />
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="vTDLS Zoom %"
                                       Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="8" Grid.Column="1" Value="{Binding TdlsZoomPercent}"
                                           Minimum="50" Maximum="200" Increment="10" />
                        </Grid>
                        <TextBlock Text="Defaults: 12 for datablocks/lists/terminal/interface, 13 for ground labels, Strips 80% / vTDLS 100%. Aircraft list also responds to Ctrl+Plus / Ctrl+Minus / Ctrl+0 while focused; Strips also has on-panel zoom buttons."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11" />
                        <Separator Margin="0,4" />
                        <TextBlock Text="Command Input"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Signature Help Placement:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <ComboBox ItemsSource="{Binding SignatureHelpPlacementOptions}"
                                      SelectedIndex="{Binding SelectedSignatureHelpPlacementIndex}"
                                      Width="120"
                                      HorizontalAlignment="Left" />
                            <TextBlock Text="Controls whether the command signature help tooltip appears above or below the command input."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <CheckBox Content="Auto-expand highlighted suggestion on Enter"
                                      IsChecked="{Binding AutoExpandSuggestionOnEnter}" />
                            <TextBlock Text="When a suggestion is highlighted (via Up/Down or click), pressing Enter inserts it before sending the command — equivalent to pressing Tab then Enter. When off, Enter sends the typed text as-is."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <TextBlock Text="Radar Display"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <CheckBox Content="EuroScope-style interactive tags"
                                      IsChecked="{Binding EuroScopeMode}" />
                            <TextBlock Text="Replaces the STARS/ERAM data block with a EuroScope pseudopilot-style tag layout, and makes individual fields clickable: alt/spd flyouts, scratchpad/handoff/squawk/runway pickers, and a heading-mode cursor preview that draws a turn arc to the hovered point. See docs/euroscope/pseudopilot.md."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,0" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <CheckBox Content="Flash 'NoLndgClnc' on datablock when approaching final without landing clearance"
                                      IsChecked="{Binding FlashNoLandingClearance}" />
                            <TextBlock Text="When the aircraft hits the no-landing-clearance warning point (1 nm from threshold, or 1000 ft above minimums on a published approach), a red 'NoLndgClnc' line flashes on the radar datablock until clearance is granted. Default on."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,0" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <TextBlock Text="Student Scope Sync"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <CheckBox Content="Sync datablock colors to the student's STARS scope"
                                      IsChecked="{Binding SyncStudentDatablockColors}" />
                            <TextBlock Text="Colors each datablock the way the student sees it in STARS: white = owned by the student, green = owned by another controller, yellow = pointed out to the student, cyan = highlighted by the student. Default on."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,0" />
                            <CheckBox Content="Mark limited datablocks with (LDB) / (PDB)"
                                      IsChecked="{Binding MarkStudentLimitedDatablocks}"
                                      Margin="0,4,0,0" />
                            <TextBlock Text="Appends (LDB) when the student sees only a limited (unassociated) datablock, and (PDB) when they see a partial datablock owned by another controller, while you keep the full datablock. Default on."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,0" />
                            <CheckBox Content="Collapse datablocks to match the student's LDB/PDB/FDB"
                                      IsChecked="{Binding CollapseStudentDatablocks}"
                                      Margin="0,4,0,0" />
                            <TextBlock Text="Instead of the (LDB)/(PDB) marker, render the reduced datablock the student actually sees — a limited block for unassociated tracks and a partial block for tracks owned by another controller. Default off."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,0" />
                            <CheckBox Content="Sync leader-line direction to the student's scope"
                                      IsChecked="{Binding SyncStudentLeaderDirection}"
                                      Margin="0,4,0,0" />
                            <TextBlock Text="Orients each datablock's leader line in the direction the student set in STARS. Datablocks you have dragged keep their position; use the radar right-click menu's 'Reset to student position' to snap one back. Default off."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,0" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <TextBlock Text="Ground Display"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <CheckBox Content="Start with all datablocks hidden"
                                      IsChecked="{Binding GroundHideDataBlocksByDefault}" />
                            <TextBlock Text="When enabled, aircraft datablocks on the ground view are hidden by default. Use right-click > Show datablock or middle-click to reveal individual datablocks."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <TextBlock Text="Overlays"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Tint datablock altitude by MVA (red below, amber at)" FontWeight="SemiBold" Margin="0,0,0,2" />
                            <TextBlock Text="An airborne IFR aircraft's datablock altitude is drawn red when below the FAA-charted Minimum Vectoring Altitude for its position and amber when within 100 ft of it. No indicator outside charted coverage or for VFR (MSAW-inhibited by default). These defaults seed each scenario by the student's position type; toggle live with the MVA button on the Radar DCB."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="12,0,0,0">
                                <CheckBox Content="GND" IsChecked="{Binding MvaHintDefaultGnd}" />
                                <CheckBox Content="TWR" IsChecked="{Binding MvaHintDefaultTwr}" />
                                <CheckBox Content="APP" IsChecked="{Binding MvaHintDefaultApp}" />
                                <CheckBox Content="CTR" IsChecked="{Binding MvaHintDefaultCtr}" />
                            </StackPanel>
                            <CheckBox Content="Show speech bubbles for SAY and pilot transmissions"
                                      IsChecked="{Binding ShowSpeechBubbles}" />
                            <TextBlock Text="When enabled, SAY-family verbs (SAY, SALT, SHDG, SPOS, SSPD, SMACH, SEAPP) and RPO pilot transmissions briefly overlay the aircraft on the Radar and Ground views with a transient bubble. Off in solo-training mode (TTS plays the pilot voice instead). A ground aircraft's bubble also appears on the Radar view when no Ground view is currently showing its airport, so prompts aren't missed."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11"
                                       Margin="28,0,0,0" />
                            <StackPanel Spacing="4"
                                        IsVisible="{Binding ShowSpeechBubbles}"
                                        Margin="28,4,0,0">
                                <CheckBox Content="Keep bubbles on screen until clicked to dismiss"
                                          IsChecked="{Binding SpeechBubblesStayUntilClicked}" />
                                <TextBlock Text="When enabled, bubbles ignore the duration timer and stay on screen until you click them on the Radar or Ground view to acknowledge and dismiss them. Applies to both green SAY/pilot bubbles and amber WARN bubbles."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           Margin="28,0,0,0" />
                                <StackPanel Spacing="4"
                                            IsVisible="{Binding !SpeechBubblesStayUntilClicked}">
                                    <TextBlock Text="Duration multiplier:"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <NumericUpDown Value="{Binding SpeechBubbleDurationMultiplier}"
                                                   Minimum="0.25"
                                                   Maximum="4.0"
                                                   Increment="0.25"
                                                   FormatString="0.00"
                                                   HorizontalAlignment="Left"
                                                   Width="120" />
                                    <TextBlock Text="Scales how long a bubble stays on screen. Bubble length is derived from the message length (about 4–12 s); 1.00 leaves it unchanged, higher values keep bubbles up proportionally longer."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                </StackPanel>
                                <CheckBox Content="Also show WARN messages as speech bubbles (amber)"
                                          IsChecked="{Binding ShowWarningSpeechBubbles}"
                                          Margin="0,4,0,0" />
                                <TextBlock Text="When enabled, warning-channel messages (e.g. a cleared command queue or a vector off procedure without an altitude) also overlay the aircraft as an amber bubble, distinct from green pilot/SAY bubbles. Shown in solo-training mode too."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           Margin="28,0,0,0" />
                                <CheckBox Content="Always show ground aircraft bubbles on the Radar view"
                                          IsChecked="{Binding AlwaysShowGroundBubblesOnRadar}"
                                          Margin="0,4,0,0" />
                                <TextBlock Text="By default a ground aircraft's bubble appears on the Radar view only when no Ground view is showing its airport. Enable this to always show ground aircraft bubbles on the Radar view, even when a Ground view for that airport is open and in focus."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           Margin="28,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="Instructor TPA cone half-angle (°):"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Margin="0,8,0,0" />
                            <NumericUpDown Value="{Binding TpaConeHalfAngleDegrees}"
                                           Minimum="1"
                                           Maximum="30"
                                           Increment="1"
                                           FormatString="0.#"
                                           HorizontalAlignment="Left"
                                           Width="120" />
                            <TextBlock Text="Width of the instructor J-Ring/Cone overlay's cone, drawn on your radar to emulate the STARS TPA cone (CONE / *P). CRC draws a razor-thin 2° cone along the aircraft's track; raise this to make the wedge easier to read on your scope. The J-Ring is unaffected, and the overlay is never shown on the student's CRC. Default 2°."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <TextBlock Text="Windows"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Always on Top" FontWeight="SemiBold" Margin="0,0,0,2" />
                            <TextBlock Text="Pin pop-out windows above all other windows. You can also toggle this with the Always on Top keybind while a window is focused." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,4" />
                            <WrapPanel Orientation="Horizontal" Margin="12,0,0,0">
                                <CheckBox Content="Main Window" IsChecked="{Binding MainWindowTopmost}" Margin="0,0,16,4" />
                                <CheckBox Content="Ground View" IsChecked="{Binding GroundViewTopmost}" Margin="0,0,16,4" />
                                <CheckBox Content="Radar View" IsChecked="{Binding RadarViewTopmost}" Margin="0,0,16,4" />
                                <CheckBox Content="Aircraft List" IsChecked="{Binding DataGridTopmost}" Margin="0,0,16,4" />
                                <CheckBox Content="Terminal" IsChecked="{Binding TerminalTopmost}" Margin="0,0,16,4" />
                                <CheckBox Content="Flight Strips" IsChecked="{Binding VStripsTopmost}" Margin="0,0,16,4" />
                                <CheckBox Content="Favorites" IsChecked="{Binding FavoritesPanelTopmost}" Margin="0,0,16,4" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Colors tab -->
            <TabItem Header="Colors">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="12">
                        <TextBlock Text="Ground View"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Background Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundBackgroundColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Taxiway Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundTaxiwayColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Taxiway Label Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundTaxiLabelColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="RAMP Edge Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundRampEdgeColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Hold Short Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundHoldShortColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Runway Fill Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundRunwayFillColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Runway Outline Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundRunwayOutlineColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Aircraft Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundAircraftColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Datablock Text Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding GroundDatablockTextColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <TextBlock Text="Brightness:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <Slider Value="{Binding GroundBrightness}" Minimum="10" Maximum="100" Width="200" TickFrequency="10" IsSnapToTickEnabled="True" />
                                <TextBlock Text="{Binding GroundBrightness, StringFormat='{}{0}%'}" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="Brightness scales the opacity of infrastructure elements (taxiways, runways, nodes) while keeping aircraft at full visibility." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" />
                            <Separator Margin="0,8" />
                            <TextBlock Text="Layer Brightness" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Satellite Image:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <Slider Value="{Binding GroundSatelliteImageBrightness}" Minimum="10" Maximum="100" Width="200" TickFrequency="10" IsSnapToTickEnabled="True" />
                                <TextBlock Text="{Binding GroundSatelliteImageBrightness, StringFormat='{}{0}%'}" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <TextBlock Text="Video Map Overlay:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <Slider Value="{Binding GroundVideoMapOverlayBrightness}" Minimum="10" Maximum="100" Width="200" TickFrequency="10" IsSnapToTickEnabled="True" />
                                <TextBlock Text="{Binding GroundVideoMapOverlayBrightness, StringFormat='{}{0}%'}" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <TextBlock Text="YAAT Layout:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <Slider Value="{Binding GroundYaatLayoutBrightness}" Minimum="10" Maximum="100" Width="200" TickFrequency="10" IsSnapToTickEnabled="True" />
                                <TextBlock Text="{Binding GroundYaatLayoutBrightness, StringFormat='{}{0}%'}" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="Adjust opacity for each ground view layer independently. Satellite and video map layers come from vNAS tower cab data." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" Margin="0,4,0,0" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <TextBlock Text="Radar View"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <CheckBox Content="Tint my assigned aircraft"
                                      IsChecked="{Binding AssignmentTintEnabled}" />
                            <StackPanel Spacing="4"
                                        IsVisible="{Binding AssignmentTintEnabled}"
                                        Margin="28,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Tint Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <ColorPicker Color="{Binding AssignmentTintColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                                </StackPanel>
                                <TextBlock Text="Color for targets and datablocks of aircraft assigned to you. Default: green." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <CheckBox Content="Tint unassigned aircraft"
                                      IsChecked="{Binding UnassignedTintEnabled}" />
                            <StackPanel Spacing="4"
                                        IsVisible="{Binding UnassignedTintEnabled}"
                                        Margin="28,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Tint Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <ColorPicker Color="{Binding UnassignedTintColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                                </StackPanel>
                                <TextBlock Text="Color for aircraft not assigned to you (or unassigned). Default: gray." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Selected Aircraft Color:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" />
                                <ColorPicker Color="{Binding SelectedColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <TextBlock Text="Color for the currently selected aircraft's symbol and datablock. Default: white." TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <TextBlock Text="Terminal Channels"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Command:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalCommandColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Response:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalResponseColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="System:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalSystemColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="SAY (controller):" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalSayColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Pilot Speech:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalPilotSpeechColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Warning:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalWarningColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Error:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalErrorColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Chat:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalChatColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="vTDLS (PDC):" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalTdlsColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Flight strips:" Foreground="{DynamicResource SubtleTextBrush}" VerticalAlignment="Center" Width="160" />
                                <ColorPicker Color="{Binding TerminalStripColor, Converter={StaticResource HexColorConverter}}" IsAlphaEnabled="False" Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <TextBlock Text="Foreground colors per terminal channel. Pilot Speech is sim-initiated transmissions in RPO mode; SAY is controller-issued SAY-class verbs; vTDLS is the ACARS-style PDC delivery line; Flight strips is strip-command echoes and feedback. Saved settings apply to the live terminal immediately."
                                       TextWrapping="Wrap" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <Button Content="Reset All Colors to Defaults"
                                Command="{Binding ResetAllColorsCommand}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Commands tab -->
            <TabItem Header="Commands" x:Name="CommandsTab">
                <DockPanel Margin="12">

                    <!-- Try it out -->
                    <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="0,12,0,0">
                        <TextBlock Text="Try it out:" Foreground="{DynamicResource SubtleTextBrush}" />
                        <TextBox Text="{Binding TestCommandInput}"
                                 Watermark="Type a command to test (e.g., FH 270, H270, T30L)" />
                        <TextBlock Text="{Binding TestCommandResult}"
                                   IsVisible="{Binding TestCommandResult, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontFamily="{StaticResource MonoFont}"
                                   Classes.error="{Binding TestCommandIsError}">
                            <TextBlock.Styles>
                                <Style Selector="TextBlock">
                                    <Setter Property="Foreground" Value="#4EC9B0" />
                                </Style>
                                <Style Selector="TextBlock.error">
                                    <Setter Property="Foreground" Value="#F44747" />
                                </Style>
                            </TextBlock.Styles>
                        </TextBlock>
                    </StackPanel>

                    <!-- Verb mapping table -->
                    <DataGrid ItemsSource="{Binding GroupedVerbMappings}"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal"
                              CanUserResizeColumns="False"
                              CanUserSortColumns="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column">
                        <DataGrid.Styles>
                            <Style Selector="DataGridRowGroupHeader">
                                <Setter Property="IsItemCountVisible" Value="False" />
                            </Style>
                        </DataGrid.Styles>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Command"
                                Binding="{Binding CommandName}"
                                IsReadOnly="True"
                                Width="150" />
                            <DataGridTextColumn Header="Verb(s)"
                                Binding="{Binding Aliases}"
                                Width="160" />
                            <DataGridTextColumn Header="Example"
                                Binding="{Binding Example}"
                                IsReadOnly="True"
                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>
            </TabItem>

            <!-- Macros tab -->
            <TabItem Header="Macros" x:Name="MacrosTab">
                <DockPanel Margin="12">

                    <TextBlock DockPanel.Dock="Top"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="11"
                               Margin="0,0,0,8"
                               Text="Define reusable command shortcuts. Use !NAME to invoke a macro. Inferred params: Name=HC, Expansion=FH &amp;1, CM &amp;2. Explicit params: Name=HC &amp;hdg &amp;alt, Expansion=FH &amp;hdg, CM &amp;alt. Explicit params control argument order." />

                    <!-- Bottom buttons for macros -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,8,0,0">
                        <Button Content="Add Macro"
                                Command="{Binding AddMacroCommand}" />
                        <Button Content="Import..."
                                x:Name="ImportMacrosButton" />
                        <Button Content="Export Selected"
                                x:Name="ExportSelectedMacrosButton" />
                        <Button Content="Export All"
                                x:Name="ExportAllMacrosButton" />
                    </StackPanel>

                    <!-- Macro table -->
                    <DataGrid x:Name="MacroDataGrid"
                              ItemsSource="{Binding MacroRows}"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="False"
                              SelectionMode="Extended"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}"
                                Width="120" />
                            <DataGridTextColumn Header="Expansion"
                                Binding="{Binding Expansion}"
                                Width="*" />
                            <DataGridTextColumn Header="Preview"
                                Binding="{Binding Preview}"
                                IsReadOnly="True"
                                Width="250" />
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X"
                                                Command="{Binding RemoveCommand}"
                                                Padding="4,0"
                                                FontSize="11"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>
            </TabItem>

            <!-- Audio tab -->
            <TabItem Header="Audio">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Input device:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <ComboBox ItemsSource="{Binding AudioInputDevices}"
                                      SelectedItem="{Binding SelectedAudioInputDeviceDisplay}"
                                      Width="360" />
                            <TextBlock Text="Pick the microphone YAAT should record from for push-to-talk speech recognition, or leave on System default to use whichever mic Windows is currently set to."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Output device:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <ComboBox ItemsSource="{Binding AudioOutputDevices}"
                                      SelectedItem="{Binding SelectedAudioOutputDeviceDisplay}"
                                      Width="360" />
                            <TextBlock Text="Used for pilot text-to-speech playback and the SAY/warning notification chime. Leave on System default to follow whichever output Windows is currently set to."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Speech tab -->
            <TabItem Header="Speech">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="12">

                        <Expander IsExpanded="{Binding SpeechEnabled, Mode=OneWay}">
                            <Expander.Header>
                                <CheckBox Content="Speech-to-text (STT)"
                                          IsChecked="{Binding SpeechEnabled}" />
                            </Expander.Header>
                            <StackPanel Spacing="12" Margin="0,8,0,0">
                                <CheckBox Content="Auto-focus command input after PTT"
                                          IsChecked="{Binding AutoFocusInputAfterSpeech}"
                                          ToolTip.Tip="When PTT/STT produces a transcript, focus the command input box so you can press Enter to send without mousing for it." />

                                <TextBlock Text="Whisper Model (speech-to-text)"
                                           FontWeight="SemiBold" />
                                <StackPanel Spacing="4">
                                    <ComboBox ItemsSource="{Binding WhisperLmKitModels}"
                                              SelectedItem="{Binding SelectedWhisperLmKitModel}"
                                              Width="420">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                    <TextBlock Text="{Binding ApproxSizeMb, StringFormat='({0} MB)'}"
                                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                                    <TextBlock Text="✓ cached"
                                                               FontSize="10"
                                                               Foreground="LightGreen"
                                                               IsVisible="{Binding IsLocallyAvailable}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Text="{Binding SelectedWhisperLmKitModel.Description}"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Download now"
                                                Command="{Binding DownloadSelectedWhisperModelCommand}"
                                                IsEnabled="{Binding SelectedWhisperLmKitModel.CanDownload, FallbackValue=False}" />
                                        <Button Content="Delete cached"
                                                Command="{Binding DeleteSelectedWhisperModelCommand}"
                                                IsEnabled="{Binding SelectedWhisperLmKitModel.CanDelete, FallbackValue=False}" />
                                        <TextBlock Text="{Binding SelectedWhisperLmKitModel.StatusMessage}"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ProgressBar Minimum="0"
                                                 Maximum="1"
                                                 Value="{Binding SelectedWhisperLmKitModel.DownloadProgress}"
                                                 IsVisible="{Binding SelectedWhisperLmKitModel.IsDownloading}"
                                                 Height="8" />
                                    <TextBlock Text="Pre-downloading here avoids the multi-second stall on your first PTT press. LM-Kit caches models under %LOCALAPPDATA%/LM-Kit/Models/ and reuses them across runs."
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                </StackPanel>

                                <TextBlock Text="LLM Model (command interpretation)"
                                           FontWeight="SemiBold" />
                                <StackPanel Spacing="4">
                                    <ComboBox ItemsSource="{Binding LlmLmKitModels}"
                                              SelectedItem="{Binding SelectedLlmLmKitModel}"
                                              Width="420">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                    <TextBlock Text="{Binding ApproxSizeMb, StringFormat='({0} MB)'}"
                                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                                    <TextBlock Text="GPU recommended"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               IsVisible="{Binding GpuRecommended}" />
                                                    <TextBlock Text="✓ cached"
                                                               FontSize="10"
                                                               Foreground="LightGreen"
                                                               IsVisible="{Binding IsLocallyAvailable}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBlock Text="{Binding SelectedLlmLmKitModel.Description}"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Download now"
                                                Command="{Binding DownloadSelectedLlmModelCommand}"
                                                IsEnabled="{Binding SelectedLlmLmKitModel.CanDownload, FallbackValue=False}" />
                                        <Button Content="Delete cached"
                                                Command="{Binding DeleteSelectedLlmModelCommand}"
                                                IsEnabled="{Binding SelectedLlmLmKitModel.CanDelete, FallbackValue=False}" />
                                        <TextBlock Text="{Binding SelectedLlmLmKitModel.StatusMessage}"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ProgressBar Minimum="0"
                                                 Maximum="1"
                                                 Value="{Binding SelectedLlmLmKitModel.DownloadProgress}"
                                                 IsVisible="{Binding SelectedLlmLmKitModel.IsDownloading}"
                                                 Height="8" />
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock Text="Or use a custom GGUF:"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                        <Button x:Name="BrowseLlmModelButton"
                                                Content="Browse..."
                                                Click="OnBrowseLlmModelClick" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding LlmModelPath, StringFormat='Source: {0}'}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11"
                                               IsVisible="{Binding LlmModelPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>

                                <TextBlock Text="Acceleration"
                                           FontWeight="SemiBold" />
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding LmKitGpuSnapshot.Summary}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <TextBlock Text="Vulkan and CPU backends ship with the application. NVIDIA CUDA 13 is a separate download (~534 MB compressed, ~700 MB on disk) because bundling it into the installer doubled its size."
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               IsVisible="{Binding IsCudaBackendSupported}" />

                                    <StackPanel Spacing="4"
                                                Margin="0,6,0,0"
                                                IsVisible="{Binding IsCudaBackendSupported}">
                                        <TextBlock Text="{Binding CudaBackend.StatusMessage}"
                                                   TextWrapping="Wrap"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   IsVisible="{Binding CudaBackend.StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        <ProgressBar Minimum="0"
                                                     Maximum="1"
                                                     Value="{Binding CudaBackend.Progress}"
                                                     IsVisible="{Binding CudaBackend.IsBusy}"
                                                     Height="8" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Download CUDA 13 runtime"
                                                    Command="{Binding InstallCudaBackendCommand}"
                                                    IsVisible="{Binding !CudaBackend.IsInstalled}"
                                                    IsEnabled="{Binding !CudaBackend.IsBusy}" />
                                            <Button Content="Cancel"
                                                    Command="{Binding CancelCudaBackendInstallCommand}"
                                                    IsVisible="{Binding CudaBackend.IsBusy}" />
                                            <Button Content="Uninstall CUDA"
                                                    Command="{Binding UninstallCudaBackendCommand}"
                                                    IsVisible="{Binding CudaBackend.IsInstalled}"
                                                    IsEnabled="{Binding !CudaBackend.IsBusy}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock Text="LLM GPU layers:"
                                                   VerticalAlignment="Center" />
                                        <NumericUpDown Value="{Binding LlmGpuLayers}"
                                                       Minimum="-1"
                                                       Maximum="100"
                                                       Width="110" />
                                        <TextBlock Text="(-1 = auto, 0 = CPU only, N = offload N layers)"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="Push-to-Talk"
                                           FontWeight="SemiBold" />
                                <StackPanel Spacing="4">
                                    <TextBlock Text="PTT key:"
                                               Foreground="{DynamicResource SubtleTextBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="PttKeyButton"
                                                Content="{Binding PttKeyDisplay}"
                                                Width="160"
                                                HorizontalContentAlignment="Center"
                                                Command="{Binding StartPttKeyCaptureCommand}" />
                                        <TextBlock Text="(click, then press a key or modifier)"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Hold this key to record speech. Default: Right Ctrl."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                    <TextBlock Text="The microphone is configured in the Audio tab."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                </StackPanel>

                                <TextBlock Text="Help improve speech recognition"
                                           FontWeight="SemiBold" />
                                <StackPanel Spacing="6">
                                    <CheckBox Content="Save my push-to-talk samples locally for review"
                                              IsChecked="{Binding SpeechSampleCaptureEnabled}" />
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11"
                                               Text="When on, every PTT recording + pipeline trace is saved locally. Nothing is uploaded automatically — review samples in the Speech Debug window and export the ones you want the devs to see, then attach them to a GitHub issue." />
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11"
                                               Text="Saved per session: audio recording, transcript at each pipeline stage, and active scenario context (callsigns, fixes, runways)." />
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                        <TextBlock Text="Max retained audio:"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubtleTextBrush}" />
                                        <NumericUpDown Value="{Binding SpeechSampleCacheMaxMb}"
                                                       Minimum="10"
                                                       Maximum="500"
                                                       Increment="10"
                                                       FormatString="0"
                                                       Width="110" />
                                        <TextBlock Text="MB (oldest samples drop when full)"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="11" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Open samples folder"
                                                Command="{Binding OpenSpeechSamplesFolderCommand}" />
                                        <Button Content="Delete all saved samples"
                                                Command="{Binding DeleteAllSpeechSamplesCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="{Binding PilotVoiceEnabled, Mode=OneWay}">
                            <Expander.Header>
                                <CheckBox Content="Text-to-speech (TTS)"
                                          IsChecked="{Binding PilotVoiceEnabled}" />
                            </Expander.Header>
                            <StackPanel Spacing="12" Margin="0,8,0,0">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Solo pilot voice"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Speaks typed solo-training pilot transmissions with the local Piper voice pack. Off by default."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock Text="Volume:"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubtleTextBrush}" />
                                        <Slider Minimum="0"
                                                Maximum="100"
                                                TickFrequency="5"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding PilotVoiceVolume}"
                                                Width="220" />
                                        <TextBlock Text="{Binding PilotVoiceVolume, StringFormat='{}{0}%'}"
                                                   MinWidth="44"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SubtleTextBrush}" />
                                    </StackPanel>
                                    <CheckBox Content="Radio effect"
                                              IsChecked="{Binding PilotVoiceRadioFxEnabled}" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Piper voice pack"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding PiperVoice.StatusMessage}"
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               IsVisible="{Binding PiperVoice.StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="1"
                                                 Value="{Binding PiperVoice.Progress}"
                                                 IsVisible="{Binding PiperVoice.IsBusy}"
                                                 Height="8" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Download Piper voice pack"
                                                Command="{Binding InstallPiperVoicePackCommand}"
                                                IsVisible="{Binding !PiperVoice.IsInstalled}"
                                                IsEnabled="{Binding !PiperVoice.IsBusy}" />
                                        <Button Content="Cancel"
                                                Command="{Binding CancelPiperVoicePackInstallCommand}"
                                                IsVisible="{Binding PiperVoice.IsBusy}" />
                                        <Button Content="Delete cached"
                                                Command="{Binding UninstallPiperVoicePackCommand}"
                                                IsVisible="{Binding PiperVoice.IsInstalled}"
                                                IsEnabled="{Binding !PiperVoice.IsBusy}" />
                                    </StackPanel>
                                    <TextBlock Text="The voice pack is shared across app upgrades and stored under YAAT app data."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Separator Margin="0,12,0,0" />

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="10"
                                   Text="Speech recognition and language model inference powered by LM-Kit.NET (Community Edition, https://lm-kit.com/products/lm-kit-net/). LM-Kit handles GGUF model loading, GPU backend selection, and constrained generation." />

                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="10"
                                   Text="Airline telephony data derived from OpenFlights (https://openflights.org/data.html), licensed under ODbL 1.0. See NOTICE and src/Yaat.Sim/Speech/Data/LICENSE-OPENFLIGHTS.txt." />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced tab -->
            <TabItem Header="Advanced">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="12">
                        <TextBlock Text="Keybinds"
                                   FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Aircraft Select Key:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="AircraftSelectKeyButton"
                                        Content="{Binding AircraftSelectKeyDisplay}"
                                        Width="160"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding StartKeyCaptureCommand}" />
                                <TextBlock Text="(click, then press a key combo)"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Pressing this key in the command input selects the aircraft matching the typed callsign without sending a command. Default: Numpad +"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <TextBlock Text="Focus Command Input Key:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="FocusInputKeyButton"
                                        Content="{Binding FocusInputKeyDisplay}"
                                        Width="160"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding StartFocusInputKeyCaptureCommand}" />
                                <TextBlock Text="(click, then press a key combo)"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Pressing this key from anywhere in the app puts focus on the command input. Default: ~ (tilde)"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <TextBlock Text="Take Control Key:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="TakeControlKeyButton"
                                        Content="{Binding TakeControlKeyDisplay}"
                                        Width="160"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding StartTakeControlKeyCaptureCommand}" />
                                <TextBlock Text="(click, then press a key combo)"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Pressing this key combo assigns the selected aircraft to yourself (RPO take control). Default: Ctrl+T"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <TextBlock Text="Always on Top Key:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="AlwaysOnTopKeyButton"
                                        Content="{Binding AlwaysOnTopKeyDisplay}"
                                        Width="160"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding StartAlwaysOnTopKeyCaptureCommand}" />
                                <TextBlock Text="(click, then press a key combo)"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Pressing this key combo toggles always-on-top for the focused pop-out window. Default: Ctrl+Shift+T"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <TextBlock Text="Quick Bookmark Key:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="QuickBookmarkKeyButton"
                                        Content="{Binding QuickBookmarkKeyDisplay}"
                                        Width="160"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding StartQuickBookmarkKeyCaptureCommand}" />
                                <TextBlock Text="(click, then press a key combo)"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Pressing this key combo drops an unnamed bookmark on the timeline at the current position. Default: Ctrl+B"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <Separator Margin="0,4" />
                        <CheckBox Content="Server Admin Mode"
                                  IsChecked="{Binding IsAdminMode}" />
                        <StackPanel Spacing="4"
                                    IsVisible="{Binding IsAdminMode}">
                            <TextBlock Text="Admin Password:"
                                       Foreground="{DynamicResource SubtleTextBrush}" />
                            <TextBox Text="{Binding AdminPassword}"
                                     PasswordChar="*"
                                     Watermark="Enter server admin password"
                                     Width="300"
                                     HorizontalAlignment="Left" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="11"
                                   Text="Admin mode allows you to see all scenarios running on the server, filter the aircraft list by scenario, and manage aircraft across all scenarios." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>
