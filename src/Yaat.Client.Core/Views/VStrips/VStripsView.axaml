<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Yaat.Client.ViewModels"
             xmlns:vstrips="using:Yaat.Client.Views.VStrips"
             x:Class="Yaat.Client.Views.VStrips.VStripsView"
             x:DataType="vm:VStripsViewModel"
             Focusable="True">

    <Grid RowDefinitions="36,*">

        <!-- Header: bay buttons + trash + printer toggle -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Background="#252529">

            <TextBlock Grid.Column="0" Text="{Binding FacilityName}"
                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                       VerticalAlignment="Center" Padding="8,0" Foreground="#B0B0B0"/>

            <ItemsControl Grid.Column="1" ItemsSource="{Binding Bays}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:StripBayViewModel">
                        <Button x:Name="BayButton"
                                Content="{Binding Name}"
                                Tag="{Binding}"
                                Margin="2,4"
                                Padding="10,2"
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="11"
                                Click="OnBayButtonClick"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Column="2"
                    x:Name="TrashZone"
                    Width="40" Height="28"
                    Margin="4"
                    Background="#3A1A1A"
                    BorderBrush="#8A3A3A"
                    BorderThickness="1"
                    CornerRadius="2"
                    ToolTip.Tip="Drag here to delete">
                <TextBlock Text="🗑" FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <ToggleButton Grid.Column="3"
                          x:Name="PrinterToggle"
                          Content="Printer"
                          Margin="4"
                          Padding="8,2"
                          IsChecked="{Binding Printer.IsOpen, Mode=TwoWay}"
                          FontSize="11"/>
        </Grid>

        <!-- Main area: selected bay's racks + printer panel overlay -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="RacksHost"
                              ItemsSource="{Binding SelectedBay.Racks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:StripRackViewModel">
                            <Border BorderBrush="#3A3A40" BorderThickness="0,0,0,1"
                                    Padding="4" Margin="0">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding RackIndex, StringFormat='Rack {0}'}"
                                               FontSize="10"
                                               Foreground="#808080"
                                               Margin="2,0,0,2"/>
                                    <ItemsControl x:Name="RackStripsHost"
                                                  Tag="{Binding}"
                                                  ItemsSource="{Binding Strips}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:StripItemViewModel">
                                                <vstrips:StripItemView Tag="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Printer side panel -->
            <Border Grid.Column="1"
                    Width="280"
                    Background="#1A1A1E"
                    BorderBrush="#3A3A40"
                    BorderThickness="1,0,0,0"
                    IsVisible="{Binding Printer.IsOpen}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Printer"
                               FontSize="12" FontWeight="Bold"
                               Padding="8,4"
                               Background="#252529"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="(empty)"
                               FontSize="11"
                               Foreground="#808080"
                               Padding="8,4"
                               IsVisible="{Binding !Printer.Queue.Count}"/>
                    <ItemsControl ItemsSource="{Binding Printer.Queue}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:StripItemViewModel">
                                <vstrips:StripItemView Tag="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

        </Grid>

    </Grid>

</UserControl>
