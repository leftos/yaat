<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vstrips="using:Yaat.Client.Views.VStrips"
        x:Class="Yaat.Client.Views.VStrips.VStripsViewWindow"
        Icon="avares://Yaat.Client.Core/Resources/icon.png"
        Title="Flight Strips">

    <!-- DataContext is the scoped VStripsViewModel (set by the host code
         when creating the window) — directly, not via a VStrips sub-path. -->
    <vstrips:VStripsView />

</Window>
