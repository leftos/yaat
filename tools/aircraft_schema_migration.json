{
  "version": 1,
  "comment": "Per-domain transforms for AircraftState/AircraftSnapshotDto refactor. Each domain moves a set of flat aircraft fields into a nested container. Used by tools/migrate_aircraft_snapshot_schema.py to upgrade pre-refactor bundles.",
  "domains": [
    {
      "name": "Voice",
      "container_field": "Voice",
      "always_emit": true,
      "fields": [
        { "old": "VoiceType", "new": "Type", "default": 1 },
        { "old": "TdlsDumped", "new": "TdlsDumped", "default": false }
      ]
    },
    {
      "name": "Pattern",
      "container_field": "Pattern",
      "always_emit": true,
      "fields": [
        { "old": "PatternSizeOverrideNm", "new": "SizeOverrideNm", "default": null },
        { "old": "PatternAltitudeOverrideFt", "new": "AltitudeOverrideFt", "default": null }
      ]
    },
    {
      "name": "HoldAnnotation",
      "container_field": "HoldAnnotation",
      "always_emit": true,
      "fields": [
        { "old": "HoldAnnotationFix", "new": "Fix", "default": null },
        { "old": "HoldAnnotationDirection", "new": "Direction", "default": 0 },
        { "old": "HoldAnnotationTurns", "new": "Turns", "default": 0 },
        { "old": "HoldAnnotationLegLength", "new": "LegLength", "default": null },
        { "old": "HoldAnnotationLegLengthInNm", "new": "LegLengthInNm", "default": false },
        { "old": "HoldAnnotationEfc", "new": "Efc", "default": 0 }
