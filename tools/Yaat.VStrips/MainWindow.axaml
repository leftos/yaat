<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vstrips="using:Yaat.Client.Views.VStrips"
        xmlns:local="using:Yaat.VStrips"
        x:Class="Yaat.VStrips.MainWindow"
        x:DataType="local:StandaloneViewModel"
        Icon="avares://Yaat.Client.Core/Resources/icon.png"
        Title="YAAT Flight Strips">

    <DockPanel>

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Connect..."
                          x:Name="ConnectMenuItem" />
                <MenuItem Header="Disconnect"
                          Command="{Binding DisconnectCommand}"
                          IsVisible="{Binding IsConnected}" />
                <Separator />
                <MenuItem Header="E_xit"
                          x:Name="ExitMenuItem" />
            </MenuItem>
            <MenuItem Header="_Room" IsEnabled="{Binding IsConnected}">
                <MenuItem Header="_Join Room..."
                          x:Name="JoinRoomMenuItem" />
                <MenuItem Header="_Leave Room"
                          Command="{Binding LeaveRoomCommand}" />
            </MenuItem>
            <MenuItem Header="_View" IsEnabled="{Binding IsInRoom}">
                <MenuItem Header="_New Window..."
                          x:Name="NewWindowMenuItem" />
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#252529"
                BorderBrush="#3A3A40"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ActiveRoomName}"
                           FontSize="11"
                           Foreground="#B0B0B0"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsInRoom}"/>
            </Grid>
        </Border>

        <!-- Center: the student-facility strips view. Additional facilities open
             as separate VStripsViewWindow instances via the 'View → New Window…'
             menu item; each holds its own VStripsViewModel scoped to one facility. -->
        <vstrips:VStripsView DataContext="{Binding VStrips}" />

    </DockPanel>

</Window>
