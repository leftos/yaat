<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vstrips="using:Yaat.Client.Views.VStrips"
        xmlns:local="using:Yaat.VStrips"
        x:Class="Yaat.VStrips.MainWindow"
        x:DataType="local:StandaloneViewModel"
        Icon="avares://Yaat.Client.Core/Resources/icon.png"
        Title="YAAT Flight Strips">

    <DockPanel>

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Connect..."
                          x:Name="ConnectMenuItem" />
                <MenuItem Header="Disconnect"
                          Command="{Binding DisconnectCommand}"
                          IsVisible="{Binding IsConnected}" />
                <Separator />
                <MenuItem Header="E_xit"
                          x:Name="ExitMenuItem" />
            </MenuItem>
            <MenuItem Header="_Room" IsEnabled="{Binding IsConnected}">
                <MenuItem Header="_Join Room..."
                          x:Name="JoinRoomMenuItem" />
                <MenuItem Header="_Leave Room"
                          Command="{Binding LeaveRoomCommand}" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Configure CRC Environments..."
                          x:Name="ConfigureCrcMenuItem" />
            </MenuItem>
        </Menu>

        <!-- Update banner -->
        <Border DockPanel.Dock="Bottom"
                Background="#1A3A5C"
                BorderBrush="#2A5A8C"
                BorderThickness="0,1,0,0"
                Padding="8,4"
                IsVisible="{Binding IsUpdateAvailable}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="12">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="YAAT Flight Strips {0} is available.">
                            <Binding Path="UpdateVersion" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <ProgressBar Grid.Column="1"
                             Width="120"
                             Height="14"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding UpdateProgress}"
                             IsVisible="{Binding IsDownloadingUpdate}"
                             VerticalAlignment="Center"
                             Margin="8,0" />
                <Button Grid.Column="2"
                        Content="Update Now"
                        FontSize="11"
                        Padding="8,2"
                        Margin="4,0"
                        Command="{Binding UpdateNowCommand}"
                        IsVisible="{Binding !IsDownloadingUpdate}" />
                <Button Grid.Column="3"
                        Content="Later"
                        FontSize="11"
                        Padding="8,2"
                        Margin="4,0"
                        Command="{Binding DismissUpdateCommand}"
                        IsVisible="{Binding !IsDownloadingUpdate}" />
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#252529"
                BorderBrush="#3A3A40"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ActiveRoomName}"
                           FontSize="11"
                           Foreground="#B0B0B0"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsInRoom}"/>
            </Grid>
        </Border>

        <!-- Center: the student-facility strips view. The facility button in
             the header lets the user switch to any accessible facility
             in-place; the standalone app is intentionally single-view (one
             window per process). -->
        <vstrips:VStripsView DataContext="{Binding VStrips}" />

    </DockPanel>

</Window>
