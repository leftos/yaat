<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Yaat.VStrips.RoomPickerWindow"
        Title="Join Room"
        Width="500"
        Height="400"
        CanResize="True"
        Icon="avares://Yaat.Client.Core/Resources/icon.png">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="RefreshButton" Content="Refresh" Padding="12,4" />
            <Button x:Name="JoinButton" Content="Join" Padding="12,4" IsDefault="True" />
            <Button x:Name="CancelButton" Content="Cancel" Padding="12,4" IsCancel="True" />
        </StackPanel>

        <DataGrid x:Name="RoomsGrid"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  SelectionMode="Single"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Creator" Binding="{Binding CreatorInitials}" Width="80" />
                <DataGridTextColumn Header="ARTCC" Binding="{Binding CreatorArtccId}" Width="60" />
                <DataGridTextColumn Header="Scenario" Binding="{Binding ScenarioName}" Width="*" />
                <DataGridTextColumn Header="Aircraft" Binding="{Binding AircraftCount}" Width="60" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>

</Window>
