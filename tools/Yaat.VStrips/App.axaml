<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Yaat.VStrips.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#B0B0B0" />
        <FontFamily x:Key="MonoFont">Consolas,Menlo,DejaVu Sans Mono,monospace</FontFamily>
        <!-- CRC vStrips palette — referenced by FlightStripControl and friends in
             Yaat.Client.Core. Must mirror the same keys defined in Yaat.Client's
             App.axaml so strips render identically across both apps. -->
        <FontFamily x:Key="StripScriptFont">Segoe Script,Lucida Handwriting,Comic Sans MS,sans-serif</FontFamily>
        <SolidColorBrush x:Key="StripCellBrush" Color="#EEEBE0" />
        <SolidColorBrush x:Key="StripBorderBrush" Color="#BFBBAE" />
        <SolidColorBrush x:Key="StripPrintedBrush" Color="#111111" />
        <SolidColorBrush x:Key="StripDropZoneBrush" Color="#9FA0B0" />
        <SolidColorBrush x:Key="StripSeparatorWhiteBrush" Color="#F5F4EB" />
        <SolidColorBrush x:Key="StripSeparatorRedBrush" Color="#A01020" />
        <SolidColorBrush x:Key="StripSeparatorGreenBrush" Color="#1C6E2E" />
        <SolidColorBrush x:Key="StripSelectedBorderBrush" Color="#FFD76A" />
    </Application.Resources>
    <Application.Styles>
        <FluentTheme DensityStyle="Compact" />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="22" />
        </Style>
        <Style Selector="DataGridCell TextBlock">
            <Setter Property="Margin" Value="4,1" />
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="MinHeight" Value="22" />
        </Style>
        <Style Selector="DataGridRow:nth-child(even) /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#0AFFFFFF" />
        </Style>
    </Application.Styles>
</Application>
