<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Yaat.VStrips.Web.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <!-- Mirror of Yaat.Client/App.axaml resources that VStripsView /
             FlightStripControl resolve via {StaticResource ...}. Without
             these the AXAML compiler still binds at parse time, but the
             at-runtime resolution returns null and panels render blank. -->
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#B0B0B0" />
        <!-- Match Yaat.Client/App.axaml: embedded JetBrains Mono first so the
             strip view renders identically in the browser tab and the
             desktop. Without this the WASM bundle falls back to Inter
             (the only font in Avalonia.Browser by default), which is
             proportional and clips callsigns. -->
        <FontFamily x:Key="MonoFont">fonts:JetBrainsMono#JetBrains Mono,Consolas,Menlo,DejaVu Sans Mono,monospace</FontFamily>
        <!-- WASM has neither the handwriting fonts nor anywhere to find a
             checkmark glyph in Inter, so JetBrains Mono is the only entry
             that can reliably render annotations. The OS handwriting names
             remain at the head of the chain so the desktop client (which
             references this same MonoFont through Yaat.Client) keeps its
             script feel. -->
        <FontFamily x:Key="StripScriptFont">Segoe Script,Lucida Handwriting,Comic Sans MS,fonts:JetBrainsMono#JetBrains Mono,sans-serif</FontFamily>
        <SolidColorBrush x:Key="StripCellBrush" Color="#EEEBE0" />
        <SolidColorBrush x:Key="StripBorderBrush" Color="#BFBBAE" />
        <SolidColorBrush x:Key="StripPrintedBrush" Color="#111111" />
        <SolidColorBrush x:Key="StripFieldNumberBrush" Color="#A02020" />
        <SolidColorBrush x:Key="StripDropZoneBrush" Color="#9FA0B0" />
        <SolidColorBrush x:Key="StripSeparatorWhiteBrush" Color="#F5F4EB" />
        <SolidColorBrush x:Key="StripSeparatorRedBrush" Color="#A01020" />
        <SolidColorBrush x:Key="StripSeparatorGreenBrush" Color="#1C6E2E" />
        <SolidColorBrush x:Key="StripDisconnectedBrush" Color="#E01020" />
        <SolidColorBrush x:Key="StripSelectedBorderBrush" Color="#FFD76A" />
    </Application.Resources>
    <Application.Styles>
        <FluentTheme DensityStyle="Compact" />
    </Application.Styles>
</Application>
