<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vtdls="using:Yaat.Client.Views.VTdls"
             x:Class="Yaat.VTdls.Web.MainView">
    <Grid Background="#FFFFFF" RowDefinitions="*,Auto">
        <vtdls:VTdlsView Grid.Row="0" x:Name="TdlsView" />
        <!-- Status footer — gives the user visible feedback on connect /
             room state since the browser tab has no other chrome. Code-
             behind updates StatusText as the connect + auto-join flow
             progresses. -->
        <Border Grid.Row="1"
                Background="#EFEFEF"
                BorderBrush="#BFBFBF"
                BorderThickness="0,1,0,0"
                Padding="8,3">
            <TextBlock x:Name="StatusBar"
                       Text="Initializing..."
                       Foreground="#303030"
                       FontFamily="Consolas,Menlo,DejaVu Sans Mono,monospace"
                       FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
